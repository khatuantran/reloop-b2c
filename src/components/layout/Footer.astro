---
const year = 2026;
---

<footer class="bg-forest text-white mt-space-96">
  <div class="max-w-[1280px] mx-auto px-[80px] py-space-64">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-space-48">
      <!-- Logo + tagline + contact -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-space-12 mb-space-16">
          <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-lime to-lime-deep shadow-clay-lime flex items-center justify-center">
            <span class="material-symbols-rounded fill text-text-on-lime !text-[22px]">recycling</span>
          </div>
          <div>
            <div class="font-display font-extrabold text-[20px] leading-none">RE-LOOP</div>
            <div class="font-mono-md text-[10px] text-white/60 mt-1 leading-none">Kinh tế tuần hoàn · Việt Nam</div>
          </div>
        </div>
        <p class="text-[14px] text-white/70 leading-relaxed mb-space-24">
          Bán rác tái chế minh bạch · 4 Tier waste · ZaloPay 60 giây · Hub Tier 3 ISO 14001.
        </p>
        <div class="space-y-space-12 text-[13px]">
          <a href="tel:19007356677" class="flex items-center gap-space-12 hover:text-lime transition">
            <span class="material-symbols-rounded fill !text-[18px] text-lime">call</span>
            <span class="font-mono-md font-semibold">1900-RELOOP (24/7)</span>
          </a>
          <a href="mailto:cs@reloop.vn" class="flex items-center gap-space-12 hover:text-lime transition">
            <span class="material-symbols-rounded fill !text-[18px] text-lime">mail</span>
            <span>cs@reloop.vn</span>
          </a>
          <div class="flex items-start gap-space-12">
            <span class="material-symbols-rounded fill !text-[18px] text-lime mt-[2px]">location_on</span>
            <span class="text-white/80">Tầng 12, Toà Crescent Plaza<br/>Q.7, TP. Hồ Chí Minh</span>
          </div>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-display font-bold text-[14px] uppercase tracking-wider text-white/90 mb-space-16">Hướng dẫn</h4>
        <ul class="space-y-space-12 text-[14px] text-white/70">
          <li><a href="/help.html" class="hover:text-lime transition">Cách hoạt động</a></li>
          <li><a href="/help.html#tiers" class="hover:text-lime transition">4 Tier S/B/C/H giải thích</a></li>
          <li><a href="/help.html" class="hover:text-lime transition">Câu hỏi thường gặp (FAQ)</a></li>
          <li><a href="/disputes.html" class="hover:text-lime transition">Tranh chấp & khiếu nại</a></li>
          <li><a href="/share.html" class="hover:text-lime transition">Cháu giúp bà · Đặt hộ</a></li>
          <li><a href="/onboarding.html" class="hover:text-lime transition">Hướng dẫn người mới</a></li>
          <li><a href="/easy.html" class="hover:text-lime transition">Chế độ Đơn giản</a></li>
          <li><a href="/notifications.html" class="hover:text-lime transition">Hộp thư thông báo</a></li>
          <li><a href="/rewards.html" class="hover:text-lime transition">Green Points & Voucher</a></li>
          <li><a href="/impact.html" class="hover:text-lime transition">Xanh nhà em — Tác động</a></li>
          <li><a href="/profile.html" class="hover:text-lime transition">Trust Score & Tạm ứng</a></li>
        </ul>
      </div>

      <!-- Certifications -->
      <div>
        <h4 class="font-display font-bold text-[14px] uppercase tracking-wider text-white/90 mb-space-16">Chứng chỉ & Tuân thủ</h4>
        <ul class="space-y-space-12 text-[14px] text-white/70">
          <li class="flex items-start gap-space-8">
            <span class="material-symbols-rounded fill !text-[16px] text-lime mt-[2px]">verified</span>
            <span>ISO 14001 — Hub Tier 3</span>
          </li>
          <li class="flex items-start gap-space-8">
            <span class="material-symbols-rounded fill !text-[16px] text-lime mt-[2px]">verified</span>
            <span>Big4 audit ESG hằng năm</span>
          </li>
          <li class="flex items-start gap-space-8">
            <span class="material-symbols-rounded fill !text-[16px] text-lime mt-[2px]">gavel</span>
            <span>NĐ 08/2022/NĐ-CP — EPR compliance</span>
          </li>
          <li class="flex items-start gap-space-8">
            <span class="material-symbols-rounded fill !text-[16px] text-lime mt-[2px]">groups</span>
            <span>Hiệp hội Tái chế Việt Nam (VRA)</span>
          </li>
          <li class="flex items-start gap-space-8">
            <span class="material-symbols-rounded fill !text-[16px] text-lime mt-[2px]">eco</span>
            <span>VNCPC — Sản xuất sạch hơn</span>
          </li>
          <li class="flex items-start gap-space-8">
            <span class="material-symbols-rounded fill !text-[16px] text-lime mt-[2px]">workspace_premium</span>
            <span>GreenTech Award 2026</span>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-display font-bold text-[14px] uppercase tracking-wider text-white/90 mb-space-16">Pháp lý & Chính sách</h4>
        <ul class="space-y-space-12 text-[14px] text-white/70">
          <li><a href="#" class="hover:text-lime transition">Chính sách bảo mật (NĐ 13/2023)</a></li>
          <li><a href="#" class="hover:text-lime transition">Điều khoản sử dụng</a></li>
          <li><a href="#" class="hover:text-lime transition">Chính sách Anti-fraud Tier C</a></li>
          <li><a href="#" class="hover:text-lime transition">Quy trình rã xác BOM minh bạch</a></li>
          <li><a href="#" class="hover:text-lime transition">Trust Score & Tạm ứng %</a></li>
          <li><a href="#" class="hover:text-lime transition">Quy trình khiếu nại BOM</a></li>
          <li><a href="#" class="hover:text-lime transition">Xuất dữ liệu cá nhân</a></li>
        </ul>
        <div class="mt-space-24 flex gap-space-12">
          <a href="#" class="w-9 h-9 rounded-2xl bg-white/10 hover:bg-lime hover:text-text-on-lime flex items-center justify-center transition">
            <span class="material-symbols-rounded fill !text-[18px]">thumb_up</span>
          </a>
          <a href="#" class="w-9 h-9 rounded-2xl bg-white/10 hover:bg-lime hover:text-text-on-lime flex items-center justify-center transition" title="Zalo OA">
            <span class="font-display font-bold text-[14px]">Z</span>
          </a>
          <a href="#" class="w-9 h-9 rounded-2xl bg-white/10 hover:bg-lime hover:text-text-on-lime flex items-center justify-center transition">
            <span class="material-symbols-rounded fill !text-[18px]">play_circle</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-space-48 pt-space-32 border-t border-white/10 flex flex-col md:flex-row justify-between items-start md:items-center gap-space-16 text-[12px] text-white/60">
      <div class="font-mono-md">
        © {year} RE-LOOP Việt Nam · Pilot 3 quận TPHCM (Q.7, Bình Thạnh, Q.4)
      </div>
      <div class="flex flex-wrap items-center gap-space-16">
        <span class="flex items-center gap-space-4">
          <span class="material-symbols-rounded !text-[14px]">language</span>
          Tiếng Việt
        </span>
        <span>·</span>
        <a href="#" class="hover:text-lime transition">Sitemap</a>
        <span>·</span>
        <a href="#" class="hover:text-lime transition">Cookie</a>
      </div>
    </div>
  </div>
</footer>
