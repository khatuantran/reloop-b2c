---
interface Props {
  icon?: string;
  title: string;
  body?: string;
}
const { icon = 'inbox', title, body } = Astro.props;
---

<div class="flex flex-col items-center justify-center text-center py-space-96 gap-space-16">
  <div class="w-20 h-20 rounded-full bg-bg-elevated border border-border-subtle flex items-center justify-center">
    <span class="material-symbols-outlined !text-[32px] text-text-tertiary">{icon}</span>
  </div>
  <h3 class="font-h4 text-h4 text-text-primary">{title}</h3>
  {body && <p class="font-body-md text-body-md text-text-secondary max-w-[400px]">{body}</p>}
  <slot />
</div>
