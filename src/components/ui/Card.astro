---
interface Props {
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  radius?: 'md' | 'lg' | 'xl';
  class?: string;
}

const { hover = false, padding = 'md', radius = 'lg', class: className = '' } = Astro.props;

const paddings = {
  sm: 'p-space-16',
  md: 'p-space-24',
  lg: 'p-space-48',
};

const radii = {
  md: 'rounded-2xl',
  lg: 'rounded-3xl',
  xl: 'rounded-3xl',
};
---

<div
  class:list={[
    'bg-bg-elevated border border-border-subtle',
    paddings[padding],
    radii[radius],
    hover && 'transition-all duration-300 ease-out-expo hover:bg-bg-surface hover:border-border-default hover:-translate-y-1',
    className,
  ]}
>
  <slot />
</div>
