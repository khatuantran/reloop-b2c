---
import RecycleScene from '../illustrations/RecycleScene.astro';
import TierSScene from '../illustrations/TierSScene.astro';
import TierCScene from '../illustrations/TierCScene.astro';
import HubWarehouse from '../illustrations/HubWarehouse.astro';
import MilestoneCelebration from '../illustrations/MilestoneCelebration.astro';
import CollectorScene from '../illustrations/CollectorScene.astro';
import OtpPhone from '../illustrations/OtpPhone.astro';
import WalletScene from '../illustrations/WalletScene.astro';
import PackageScene from '../illustrations/PackageScene.astro';
import GreenPointsBadge from '../illustrations/GreenPointsBadge.astro';

interface Chip { icon: string; label: string; value: string; tone?: 'mint' | 'butter' | 'sky' | 'peach' | 'blush' }
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  tier?: 'S' | 'B' | 'C' | 'H';
  illustration?: 'recycle' | 'tier-s' | 'tier-c' | 'hub' | 'milestone' | 'collector' | 'otp' | 'wallet' | 'package' | 'gp';
  accent?: 'tier-s' | 'amber-deep' | 'info' | 'tier-c';
  chips?: Chip[];
  back?: { href: string; label: string };
}

const {
  eyebrow,
  title,
  subtitle,
  illustration = 'recycle',
  accent = 'tier-s',
  chips = [],
  back,
} = Astro.props;

const accentChipClass: Record<string, string> = {
  'tier-s': 'bg-clay-mint border-tier-s/30 text-tier-s',
  'amber-deep': 'bg-clay-butter border-amber-deep/30 text-amber-deep',
  'info': 'bg-clay-sky border-info/30 text-info',
  'tier-c': 'bg-clay-peach border-tier-c/30 text-tier-c',
};

const toneClass: Record<string, string> = {
  mint: 'bg-clay-mint border-tier-s/30',
  butter: 'bg-clay-butter border-amber-deep/30',
  sky: 'bg-clay-sky border-info/30',
  peach: 'bg-clay-peach border-tier-c/30',
  blush: 'bg-clay-blush border-tier-h/30',
};
const toneAccent: Record<string, string> = {
  mint: 'text-tier-s',
  butter: 'text-amber-deep',
  sky: 'text-info',
  peach: 'text-tier-c',
  blush: 'text-tier-h',
};
---

{back && (
  <a href={back.href} class="inline-flex items-center gap-space-8 font-mono-md text-[12px] text-text-secondary hover:text-tier-s font-semibold mb-space-16">
    <span class="material-symbols-rounded !text-[16px]">arrow_back</span>
    {back.label}
  </a>
)}

<section class="grad-hero rounded-[40px] px-space-48 py-space-32 border border-border-subtle mb-space-32 relative overflow-hidden">
  <div class="grid grid-cols-[1.3fr_1fr] gap-space-32 items-center">
    <div class="relative z-10">
      <span class={`font-mono-md text-[11px] uppercase tracking-[0.2em] font-bold border-2 rounded-full px-space-12 py-[4px] inline-flex items-center gap-space-8 shadow-clay-sm mb-space-12 ${accentChipClass[accent]}`}>
        {eyebrow}
      </span>
      <h1 class="font-display-l text-[40px] font-extrabold leading-[1.05] tracking-tight text-text-primary mb-space-8">{title}</h1>
      {subtitle && <p class="font-body-lg text-body-lg text-text-secondary mb-space-16">{subtitle}</p>}
      {chips.length > 0 && (
        <div class="flex flex-wrap gap-space-12">
          {chips.map((c) => (
            <div class={`border-2 rounded-2xl px-space-16 py-space-12 shadow-clay-sm flex items-center gap-space-12 ${toneClass[c.tone ?? 'mint']}`}>
              <span class={`material-symbols-rounded fill !text-[24px] ${toneAccent[c.tone ?? 'mint']}`}>{c.icon}</span>
              <div class="flex flex-col">
                <span class={`font-mono-md text-[10px] uppercase tracking-wider font-semibold ${toneAccent[c.tone ?? 'mint']}`}>{c.label}</span>
                <span class="font-mono-md text-[13px] text-text-primary font-bold tabular-nums">{c.value}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="relative h-[240px]">
      {illustration === 'recycle' && <RecycleScene class="absolute inset-0 w-full h-full" />}
      {illustration === 'tier-s' && <TierSScene class="absolute inset-0 w-full h-full" />}
      {illustration === 'tier-c' && <TierCScene class="absolute inset-0 w-full h-full" />}
      {illustration === 'hub' && <HubWarehouse class="absolute inset-0 w-full h-full" />}
      {illustration === 'milestone' && <MilestoneCelebration class="absolute inset-0 w-full h-full" />}
      {illustration === 'collector' && <CollectorScene class="absolute inset-0 w-full h-full" />}
      {illustration === 'otp' && <OtpPhone class="absolute inset-0 w-full h-full" />}
      {illustration === 'wallet' && <WalletScene class="absolute inset-0 w-full h-full" />}
      {illustration === 'package' && <PackageScene class="absolute inset-0 w-full h-full" />}
      {illustration === 'gp' && <GreenPointsBadge class="absolute inset-0 w-full h-full" />}
    </div>
  </div>
</section>
