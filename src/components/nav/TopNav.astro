---
import { USER, WALLET } from '../../lib/mock';
import { formatVND } from '../../lib/format';

interface Props {
  active?: 'home' | 'orders' | 'wallet' | 'profile';
}
const { active = 'home' } = Astro.props;

const links = [
  { id: 'home', label: 'Trang chủ', href: '/index.html' },
  { id: 'orders', label: 'Đơn của tôi', href: '/orders.html' },
  { id: 'wallet', label: 'Ví', href: '/wallet.html' },
  { id: 'profile', label: 'Hồ sơ', href: '/profile.html' },
] as const;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 h-20 backdrop-blur-lg border-b border-border-subtle"
  style="background-color: rgba(229, 237, 221, 0.85);"
>
  <div class="max-w-[1280px] mx-auto h-full flex justify-between items-center px-[80px]">
    <a href="/index.html" class="flex items-center gap-space-12">
      <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-lime to-lime-deep shadow-clay-lime flex items-center justify-center">
        <span class="material-symbols-rounded fill text-text-on-lime !text-[22px]">recycling</span>
      </div>
      <div class="flex flex-col">
        <span class="font-display text-[20px] font-extrabold tracking-tight text-text-primary leading-none">RE-LOOP</span>
        <span class="font-mono-md text-[10px] text-text-tertiary leading-none mt-1">Q.7 · TPHCM</span>
      </div>
    </a>

    <div class="hidden md:flex items-center gap-space-8">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'font-body-md text-[14px] font-medium transition-all duration-200 px-space-16 py-space-8 rounded-full',
              active === link.id
                ? 'bg-clay-mint text-tier-s shadow-clay-sm'
                : 'text-text-secondary hover:text-text-primary hover:bg-bg-elevated/60',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-space-8">
      <a
        href="/rewards.html"
        title="Green Points"
        class="w-10 h-10 rounded-full bg-bg-elevated border border-border-subtle hover:border-lime-deep shadow-clay-sm hover:shadow-clay flex items-center justify-center transition-all"
      >
        <span class="material-symbols-rounded fill !text-[20px] text-tier-s">redeem</span>
      </a>
      <a
        href="/notifications.html"
        title="Thông báo"
        class="w-10 h-10 rounded-full bg-bg-elevated border border-border-subtle hover:border-lime-deep shadow-clay-sm hover:shadow-clay flex items-center justify-center transition-all relative"
      >
        <span class="material-symbols-rounded fill !text-[20px] text-text-secondary">notifications</span>
        <span class="absolute top-[6px] right-[6px] w-2 h-2 rounded-full bg-tier-h"></span>
      </a>
      <a
        href="/help.html"
        title="Trợ giúp"
        class="w-10 h-10 rounded-full bg-bg-elevated border border-border-subtle hover:border-lime-deep shadow-clay-sm hover:shadow-clay flex items-center justify-center transition-all"
      >
        <span class="material-symbols-rounded fill !text-[20px] text-text-secondary">help</span>
      </a>
      <a
        href="/wallet.html"
        class="px-space-16 py-space-8 rounded-full bg-bg-elevated border border-border-subtle hover:border-lime-deep shadow-clay-sm hover:shadow-clay flex items-center gap-space-8 transition-all"
      >
        <span class="material-symbols-rounded fill !text-[16px] text-tier-s">account_balance_wallet</span>
        <span class="font-mono-md text-[13px] text-text-primary tabular-nums font-semibold">{formatVND(WALLET.zaloPayBalance)}</span>
      </a>
      <!-- Account dropdown (CSS hover) -->
      <div class="relative group">
        <button class="flex items-center gap-space-4 pl-space-4 pr-space-8 py-[2px] rounded-full bg-bg-elevated border border-border-subtle hover:border-tier-s/50 shadow-clay-sm hover:shadow-clay transition">
          <div class="w-9 h-9 rounded-full bg-gradient-to-br from-clay-mint to-lime-soft border-2 border-tier-s/40 flex items-center justify-center">
            <span class="font-display text-[15px] font-extrabold text-tier-s">{USER.name[0]}</span>
          </div>
          <span class="material-symbols-rounded !text-[16px] text-text-tertiary group-hover:rotate-180 transition">expand_more</span>
        </button>
        <!-- Dropdown menu -->
        <div class="absolute right-0 top-[calc(100%+8px)] w-[280px] bg-bg-elevated rounded-2xl shadow-clay-lg border border-border-subtle p-space-12 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
          <!-- Current user -->
          <div class="bg-clay-mint rounded-xl p-space-12 mb-space-8 flex items-center gap-space-12 border border-tier-s/30">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-clay-mint to-lime-soft border-2 border-tier-s flex items-center justify-center">
              <span class="font-display text-[16px] font-extrabold text-tier-s">{USER.name[0]}</span>
            </div>
            <div class="flex-1 min-w-0">
              <span class="font-display font-bold text-[13px] text-text-primary block truncate">{USER.name}</span>
              <span class="font-mono-md text-[10px] text-tier-s">● Đang đăng nhập</span>
            </div>
          </div>
          <!-- Quick links -->
          <a href="/profile.html" class="flex items-center gap-space-8 px-space-12 py-space-8 rounded-xl hover:bg-bg-surface transition">
            <span class="material-symbols-rounded !text-[18px] text-text-secondary">person</span>
            <span class="font-body-md text-[13px] text-text-primary font-semibold">Hồ sơ</span>
          </a>
          <a href="/profile/edit.html" class="flex items-center gap-space-8 px-space-12 py-space-8 rounded-xl hover:bg-bg-surface transition">
            <span class="material-symbols-rounded !text-[18px] text-text-secondary">settings</span>
            <span class="font-body-md text-[13px] text-text-primary font-semibold">Cài đặt</span>
          </a>
          <a href="/easy.html" class="flex items-center gap-space-8 px-space-12 py-space-8 rounded-xl hover:bg-bg-surface transition">
            <span class="material-symbols-rounded !text-[18px] text-amber-deep">accessibility_new</span>
            <span class="font-body-md text-[13px] text-text-primary font-semibold">Chế độ Đơn giản</span>
          </a>
          <div class="h-px bg-border-subtle my-space-8"></div>
          <a href="/login.html" class="flex items-center gap-space-8 px-space-12 py-space-8 rounded-xl hover:bg-bg-surface transition">
            <span class="material-symbols-rounded !text-[18px] text-info">switch_account</span>
            <span class="font-body-md text-[13px] text-text-primary font-semibold">Đổi tài khoản</span>
          </a>
          <a href="/signup.html" class="flex items-center gap-space-8 px-space-12 py-space-8 rounded-xl hover:bg-bg-surface transition">
            <span class="material-symbols-rounded !text-[18px] text-tier-s">person_add</span>
            <span class="font-body-md text-[13px] text-text-primary font-semibold">Đăng ký mới</span>
          </a>
          <a href="/login.html" class="flex items-center gap-space-8 px-space-12 py-space-8 rounded-xl hover:bg-clay-blush transition">
            <span class="material-symbols-rounded !text-[18px] text-tier-h">logout</span>
            <span class="font-body-md text-[13px] text-tier-h font-semibold">Đăng xuất</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>
