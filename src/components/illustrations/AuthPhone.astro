---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---

<svg viewBox="0 0 400 400" class={className} xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="ap-bg" cx="50%" cy="40%">
      <stop offset="0%" stop-color="#52E08D" stop-opacity="0.30"/>
      <stop offset="100%" stop-color="#52E08D" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="ap-phone" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1F2A28"/>
      <stop offset="100%" stop-color="#0F1F18"/>
    </linearGradient>
    <linearGradient id="ap-screen" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#9CF5BF"/>
      <stop offset="50%" stop-color="#52E08D"/>
      <stop offset="100%" stop-color="#0F6635"/>
    </linearGradient>
    <radialGradient id="ap-shield" cx="35%" cy="25%">
      <stop offset="0%" stop-color="#FFE066"/>
      <stop offset="100%" stop-color="#E8B340"/>
    </radialGradient>
  </defs>

  <circle cx="200" cy="200" r="180" fill="url(#ap-bg)"/>

  <!-- Sparkle dots -->
  <g>
    <circle cx="60" cy="80" r="2.5" fill="#7AEFA8" opacity="0.7"/>
    <circle cx="340" cy="70" r="3" fill="#FFE9B3" opacity="0.7"/>
    <circle cx="50" cy="320" r="2.5" fill="#52E08D" opacity="0.7"/>
    <circle cx="350" cy="320" r="2.5" fill="#FFD960" opacity="0.7"/>
  </g>

  <!-- Phone shadow -->
  <ellipse cx="200" cy="365" rx="80" ry="9" fill="#0F1F18" opacity="0.20"/>

  <!-- Phone body -->
  <g transform="translate(200,200)">
    <rect x="-72" y="-130" width="144" height="260" rx="28" fill="url(#ap-phone)"/>
    <rect x="-66" y="-124" width="132" height="248" rx="22" fill="#FAFAF7"/>
    <!-- notch -->
    <rect x="-22" y="-130" width="44" height="6" rx="3" fill="#0F1F18"/>
    <!-- screen content area -->
    <rect x="-66" y="-110" width="132" height="234" rx="6" fill="url(#ap-screen)" opacity="0.10"/>

    <!-- App header -->
    <g transform="translate(0,-95)">
      <text text-anchor="middle" font-size="11" font-weight="800" fill="#0F3D26" font-family="Inter" letter-spacing="2">RE-LOOP</text>
      <text text-anchor="middle" y="14" font-size="8" fill="#7C8A82" font-family="JetBrains Mono">Đăng nhập an toàn</text>
    </g>

    <!-- Shield icon center -->
    <g transform="translate(0,-30)">
      <circle r="32" fill="#0F3D26" opacity="0.10"/>
      <path d="M-22 -22 L0 -32 L22 -22 L22 12 Q22 24 0 32 Q-22 24 -22 12 Z" fill="url(#ap-shield)"/>
      <path d="M-12 0 L-3 8 L12 -8" stroke="#0F3D26" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </g>

    <!-- OTP cells (6 cells fitted inside phone screen) -->
    <g transform="translate(0,30)">
      <rect x="-56" y="-9" width="16" height="20" rx="3" fill="#C7F2D6"/>
      <text x="-48" y="6" text-anchor="middle" font-size="12" font-weight="800" fill="#2BB36A" font-family="JetBrains Mono">2</text>
      <rect x="-37" y="-9" width="16" height="20" rx="3" fill="#C7F2D6"/>
      <text x="-29" y="6" text-anchor="middle" font-size="12" font-weight="800" fill="#2BB36A" font-family="JetBrains Mono">6</text>
      <rect x="-18" y="-9" width="16" height="20" rx="3" fill="#C7F2D6"/>
      <text x="-10" y="6" text-anchor="middle" font-size="12" font-weight="800" fill="#2BB36A" font-family="JetBrains Mono">0</text>
      <rect x="1" y="-9" width="16" height="20" rx="3" fill="#FAFAF7" stroke="#9CF5BF" stroke-width="1.5"/>
      <rect x="20" y="-9" width="16" height="20" rx="3" fill="#FAFAF7" stroke="#E5EDDD" stroke-width="1.5"/>
      <rect x="39" y="-9" width="16" height="20" rx="3" fill="#FAFAF7" stroke="#E5EDDD" stroke-width="1.5"/>
    </g>

    <!-- Input row -->
    <g transform="translate(0,68)">
      <rect x="-50" y="-8" width="100" height="20" rx="10" fill="#E5EDDD"/>
      <text x="-30" y="6" font-size="9" fill="#7C8A82" font-family="JetBrains Mono">090X 123 456</text>
      <circle cx="40" cy="2" r="6" fill="#52E08D"/>
      <text x="40" y="6" text-anchor="middle" font-size="8" fill="white" font-weight="800">✓</text>
    </g>

    <!-- CTA button -->
    <g transform="translate(0,98)">
      <rect x="-50" y="-10" width="100" height="22" rx="11" fill="#0F3D26"/>
      <text text-anchor="middle" y="5" font-size="10" font-weight="800" fill="#9CF5BF" font-family="Inter">Xác nhận OTP</text>
    </g>
  </g>

  <!-- Floating shield top-right -->
  <g transform="translate(310,110)">
    <ellipse cx="0" cy="22" rx="22" ry="3" fill="#0F1F18" opacity="0.18"/>
    <circle r="22" fill="white" stroke="#2BB36A" stroke-width="2"/>
    <path d="M-10 -10 L0 -16 L10 -10 L10 6 Q10 12 0 18 Q-10 12 -10 6 Z" fill="#52E08D"/>
    <path d="M-5 0 L-1 4 L6 -4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </g>

  <!-- Floating fingerprint top-left -->
  <g transform="translate(85,135)">
    <ellipse cx="0" cy="22" rx="20" ry="3" fill="#0F1F18" opacity="0.18"/>
    <circle r="20" fill="white" stroke="#E8B340" stroke-width="2"/>
    <g stroke="#E8B340" stroke-width="2" fill="none" stroke-linecap="round">
      <path d="M-8 -2 Q0 -10 8 -2"/>
      <path d="M-9 4 Q0 -4 9 4"/>
      <path d="M-7 9 Q0 3 7 9"/>
      <path d="M-4 12 L4 12"/>
    </g>
  </g>

  <!-- Sparkle stars -->
  <g>
    <g transform="translate(95,260)">
      <path d="M0 -10 L2 -2 L10 0 L2 2 L0 10 L-2 2 L-10 0 L-2 -2 Z" fill="#FFE9B3"/>
    </g>
    <g transform="translate(310,260)">
      <path d="M0 -8 L1.5 -1.5 L8 0 L1.5 1.5 L0 8 L-1.5 1.5 L-8 0 L-1.5 -1.5 Z" fill="#7AEFA8"/>
    </g>
  </g>

</svg>
