---
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---

<svg viewBox="0 0 400 400" class={className} xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="cs-sky" cx="50%" cy="40%">
      <stop offset="0%" stop-color="#9CF5BF" stop-opacity="0.35"/>
      <stop offset="100%" stop-color="#9CF5BF" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="cs-truck" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#7AEFA8"/>
      <stop offset="100%" stop-color="#1F9956"/>
    </linearGradient>
    <linearGradient id="cs-truck-cabin" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#52E08D"/>
      <stop offset="100%" stop-color="#0F6635"/>
    </linearGradient>
    <linearGradient id="cs-window" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#C8FAD9"/>
      <stop offset="100%" stop-color="#7AEFA8"/>
    </linearGradient>
    <radialGradient id="cs-pin" cx="35%" cy="30%">
      <stop offset="0%" stop-color="#FFB8A8"/>
      <stop offset="100%" stop-color="#E8758F"/>
    </radialGradient>
    <linearGradient id="cs-road" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#A8C29A"/>
      <stop offset="100%" stop-color="#88AA77"/>
    </linearGradient>
  </defs>

  <!-- Sky backdrop -->
  <rect width="400" height="280" fill="url(#cs-sky)"/>

  <!-- Far buildings silhouette -->
  <g opacity="0.45" fill="#88AA77">
    <rect x="20" y="180" width="40" height="80"/>
    <rect x="55" y="160" width="25" height="100"/>
    <rect x="320" y="170" width="30" height="90"/>
    <rect x="345" y="190" width="35" height="70"/>
    <polygon points="78,160 88,150 88,260 78,260"/>
    <polygon points="312,170 322,160 322,260 312,260"/>
  </g>
  <!-- Building windows -->
  <g fill="#FFE066" opacity="0.6">
    <rect x="28" y="195" width="4" height="6"/>
    <rect x="40" y="195" width="4" height="6"/>
    <rect x="28" y="215" width="4" height="6"/>
    <rect x="40" y="215" width="4" height="6"/>
    <rect x="60" y="180" width="4" height="6"/>
    <rect x="70" y="180" width="4" height="6"/>
    <rect x="328" y="190" width="4" height="6"/>
    <rect x="340" y="190" width="4" height="6"/>
    <rect x="328" y="215" width="4" height="6"/>
  </g>

  <!-- Map pin (background, destination) -->
  <g transform="translate(320,135)">
    <ellipse cx="0" cy="42" rx="14" ry="3" fill="#0F1F18" opacity="0.22"/>
    <path d="M0 -28 Q22 -28 22 -8 Q22 10 0 38 Q-22 10 -22 -8 Q-22 -28 0 -28 Z" fill="url(#cs-pin)"/>
    <circle r="9" cy="-10" fill="white"/>
    <circle r="5" cy="-10" fill="#E8758F"/>
  </g>

  <!-- Road -->
  <path d="M0 280 L400 270 L400 340 L0 350 Z" fill="url(#cs-road)"/>
  <!-- Road dashes -->
  <g stroke="#FAFAF7" stroke-width="3" stroke-dasharray="14 12" opacity="0.85">
    <line x1="0" y1="312" x2="400" y2="305"/>
  </g>

  <!-- Route polyline (curve from left to pin) -->
  <path d="M30 250 Q120 200 200 220 Q280 240 318 160" stroke="#52E08D" stroke-width="4" fill="none" stroke-linecap="round" stroke-dasharray="2 6" opacity="0.85"/>

  <!-- Truck shadow -->
  <ellipse cx="180" cy="282" rx="98" ry="9" fill="#0F1F18" opacity="0.22"/>

  <!-- Truck body -->
  <g>
    <!-- box cargo -->
    <rect x="92" y="195" width="115" height="78" rx="8" fill="url(#cs-truck)"/>
    <rect x="100" y="205" width="98" height="58" rx="4" fill="#0F6635" opacity="0.20"/>
    <!-- recycle logo on side -->
    <circle cx="148" cy="234" r="22" fill="white" opacity="0.95"/>
    <text x="148" y="242" text-anchor="middle" font-size="28" fill="#2BB36A" font-weight="800">♻</text>
    <!-- side ribs -->
    <g stroke="#0F6635" stroke-width="1" opacity="0.4">
      <line x1="190" y1="205" x2="190" y2="263"/>
      <line x1="180" y1="205" x2="180" y2="263"/>
    </g>

    <!-- cabin -->
    <path d="M207 215 L240 215 Q258 215 258 232 L258 273 L207 273 Z" fill="url(#cs-truck-cabin)"/>
    <!-- windshield -->
    <path d="M212 220 Q230 220 252 230 L252 247 L212 247 Z" fill="url(#cs-window)"/>
    <line x1="232" y1="220" x2="232" y2="247" stroke="#0F6635" stroke-width="1" opacity="0.4"/>
    <!-- door handle -->
    <rect x="222" y="258" width="8" height="2" rx="1" fill="#0F3D26"/>
    <!-- headlight -->
    <ellipse cx="256" cy="258" rx="3" ry="4" fill="#FFE066"/>
    <!-- bumper -->
    <rect x="207" y="270" width="51" height="6" rx="2" fill="#0F3D26"/>

    <!-- wheels -->
    <g>
      <circle cx="120" cy="278" r="14" fill="#1F2A28"/>
      <circle cx="120" cy="278" r="6" fill="#525C5A"/>
      <circle cx="120" cy="278" r="2" fill="#9CF5BF"/>
    </g>
    <g>
      <circle cx="180" cy="278" r="14" fill="#1F2A28"/>
      <circle cx="180" cy="278" r="6" fill="#525C5A"/>
      <circle cx="180" cy="278" r="2" fill="#9CF5BF"/>
    </g>
    <g>
      <circle cx="232" cy="278" r="14" fill="#1F2A28"/>
      <circle cx="232" cy="278" r="6" fill="#525C5A"/>
      <circle cx="232" cy="278" r="2" fill="#9CF5BF"/>
    </g>
  </g>

  <!-- Speed lines -->
  <g stroke="#52E08D" stroke-width="2.5" stroke-linecap="round" opacity="0.55">
    <line x1="40" y1="220" x2="68" y2="220"/>
    <line x1="50" y1="240" x2="80" y2="240"/>
    <line x1="35" y1="260" x2="60" y2="260"/>
  </g>

  <!-- Cloud -->
  <g transform="translate(80,90)" fill="white" opacity="0.85">
    <ellipse cx="0" cy="0" rx="30" ry="13"/>
    <ellipse cx="-20" cy="5" rx="18" ry="10"/>
    <ellipse cx="20" cy="5" rx="20" ry="11"/>
    <ellipse cx="-7" cy="-6" rx="13" ry="8"/>
  </g>

  <!-- Sparkle stars -->
  <g>
    <g transform="translate(265,90)">
      <path d="M0 -10 L2 -2 L10 0 L2 2 L0 10 L-2 2 L-10 0 L-2 -2 Z" fill="#FFE9B3"/>
    </g>
    <g transform="translate(155,110)">
      <path d="M0 -8 L1.5 -1.5 L8 0 L1.5 1.5 L0 8 L-1.5 1.5 L-8 0 L-1.5 -1.5 Z" fill="#7AEFA8"/>
    </g>
  </g>

  <!-- ETA badge -->
  <g transform="translate(80,360)">
    <rect x="-44" y="-16" width="88" height="32" rx="16" fill="#0F1F18" opacity="0.18" transform="translate(0,3)"/>
    <rect x="-44" y="-16" width="88" height="32" rx="16" fill="white" stroke="#2BB36A" stroke-width="2"/>
    <text x="0" y="-2" text-anchor="middle" font-size="9" font-weight="700" fill="#2BB36A" font-family="JetBrains Mono" letter-spacing="1">ETA</text>
    <text x="0" y="11" text-anchor="middle" font-size="13" font-weight="800" fill="#0F3D26" font-family="JetBrains Mono">12 phút</text>
  </g>
</svg>
