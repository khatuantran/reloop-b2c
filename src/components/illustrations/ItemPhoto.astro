---
interface Props {
  item: 'pet' | 'carton' | 'aluminum' | 'paper'
       | 'fridge' | 'sofa' | 'tv' | 'washer'
       | 'mainboard' | 'wire-cu' | 'motor' | 'fan'
       | 'pin-aa' | 'oil' | 'pin-li' | 'bulb';
  class?: string;
}
const { item, class: className = '' } = Astro.props;
---

<svg viewBox="0 0 400 300" class={className} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
  <defs>
    {/* Tier S — green tones */}
    <linearGradient id={`bg-${item}`} x1="0" y1="0" x2="0" y2="1">
      {(['pet','carton','aluminum','paper'] as const).includes(item as any) && (<>
        <stop offset="0%" stop-color="#D8F5E3"/>
        <stop offset="100%" stop-color="#9CF5BF"/>
      </>)}
      {(['fridge','sofa','tv','washer'] as const).includes(item as any) && (<>
        <stop offset="0%" stop-color="#FFF1D0"/>
        <stop offset="100%" stop-color="#FFD18A"/>
      </>)}
      {(['mainboard','wire-cu','motor','fan'] as const).includes(item as any) && (<>
        <stop offset="0%" stop-color="#FFE2D5"/>
        <stop offset="100%" stop-color="#FFB89A"/>
      </>)}
      {(['pin-aa','oil','pin-li','bulb'] as const).includes(item as any) && (<>
        <stop offset="0%" stop-color="#FFD9DC"/>
        <stop offset="100%" stop-color="#FFA8B3"/>
      </>)}
    </linearGradient>
    <radialGradient id={`spot-${item}`} cx="50%" cy="40%">
      <stop offset="0%" stop-color="white" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="white" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <rect width="400" height="300" fill={`url(#bg-${item})`}/>
  <ellipse cx="200" cy="120" rx="220" ry="140" fill={`url(#spot-${item})`}/>
  <ellipse cx="200" cy="260" rx="160" ry="14" fill="#0F1F18" opacity="0.18"/>

  {/* ============== TIER S ============== */}
  {item === 'pet' && (
    <g>
      {/* 3 PET bottles standing */}
      {[120, 200, 280].map((cx, i) => (
        <g transform={`translate(${cx}, 90)`}>
          {/* cap */}
          <rect x="-10" y="0" width="20" height="14" rx="3" fill={i === 1 ? '#52E08D' : '#FFD960'}/>
          <rect x="-12" y="13" width="24" height="6" rx="2" fill="#0F6635"/>
          {/* neck */}
          <rect x="-7" y="19" width="14" height="14" fill="#FAFAF7"/>
          {/* body */}
          <path d="M-22 33 Q-26 50 -26 90 Q-26 130 -22 145 L22 145 Q26 130 26 90 Q26 50 22 33 Z" fill="#FAFAF7" opacity="0.92"/>
          {/* label */}
          <rect x="-22" y="70" width="44" height="28" fill={i === 1 ? '#52E08D' : '#FFE066'} opacity="0.85"/>
          <text x="0" y="89" text-anchor="middle" font-size="9" font-weight="800" fill="#0F3D26" font-family="Inter">PET 500ml</text>
          {/* highlight */}
          <path d="M-15 40 Q-18 80 -15 130" stroke="white" stroke-width="3" fill="none" opacity="0.6" stroke-linecap="round"/>
        </g>
      ))}
      {/* "PET" big sticker */}
      <g transform="translate(60,60)">
        <rect x="-22" y="-12" width="44" height="24" rx="4" fill="#0F3D26"/>
        <text x="0" y="6" text-anchor="middle" font-size="13" font-weight="800" fill="#9CF5BF" font-family="Inter">♻ PET</text>
      </g>
    </g>
  )}

  {item === 'carton' && (
    <g>
      {/* Stack of carton boxes */}
      <g transform="translate(120,100)">
        <path d="M0 60 L80 30 L160 60 L80 90 Z" fill="#A07033"/>
        <path d="M0 60 L0 130 L80 160 L80 90 Z" fill="#7A5410"/>
        <path d="M160 60 L160 130 L80 160 L80 90 Z" fill="#5A3F1A"/>
        <line x1="80" y1="90" x2="80" y2="160" stroke="#3F2A0F" stroke-width="1"/>
        {/* tape */}
        <path d="M30 75 L110 45 L130 51 L50 81 Z" fill="#FFD960" opacity="0.92"/>
        {/* label */}
        <rect x="20" y="105" width="48" height="20" rx="2" fill="white" opacity="0.95"/>
        <text x="44" y="119" text-anchor="middle" font-size="9" font-weight="800" fill="#0F3D26" font-family="Inter">CARTON</text>
      </g>
      {/* Smaller box on top */}
      <g transform="translate(220,60)">
        <path d="M0 30 L40 15 L80 30 L40 45 Z" fill="#C9A675"/>
        <path d="M0 30 L0 65 L40 80 L40 45 Z" fill="#A07033"/>
        <path d="M80 30 L80 65 L40 80 L40 45 Z" fill="#7A5410"/>
      </g>
      {/* Recycle stamp */}
      <g transform="translate(70,80)">
        <circle r="22" fill="none" stroke="#0F3D26" stroke-width="2"/>
        <text y="6" text-anchor="middle" font-size="22" fill="#0F3D26">♻</text>
      </g>
    </g>
  )}

  {item === 'aluminum' && (
    <g>
      {/* Aluminum cans cluster */}
      {[
        { x: 110, y: 110, color: '#E8758F' },
        { x: 170, y: 90, color: '#52E08D' },
        { x: 230, y: 110, color: '#3B8DD1' },
        { x: 290, y: 90, color: '#FFB8A8' },
        { x: 145, y: 175, color: '#FFD960' },
        { x: 215, y: 175, color: '#9F7CD9' },
        { x: 280, y: 175, color: '#52E08D' },
      ].map((c) => (
        <g transform={`translate(${c.x}, ${c.y})`}>
          <ellipse cx="0" cy="60" rx="24" ry="6" fill="#0F1F18" opacity="0.18"/>
          {/* can body */}
          <rect x="-22" y="-25" width="44" height="80" rx="3" fill={c.color}/>
          {/* top */}
          <ellipse cx="0" cy="-25" rx="22" ry="6" fill="#D8DEDC"/>
          <ellipse cx="0" cy="-25" rx="18" ry="4" fill="#9FA9A6"/>
          {/* bottom */}
          <ellipse cx="0" cy="55" rx="22" ry="6" fill="#525C5A"/>
          {/* label band */}
          <rect x="-22" y="0" width="44" height="22" fill="white" opacity="0.30"/>
          {/* highlight */}
          <rect x="-18" y="-20" width="4" height="70" fill="white" opacity="0.45"/>
          {/* pull tab */}
          <rect x="-4" y="-29" width="8" height="3" rx="1" fill="#525C5A"/>
        </g>
      ))}
      {/* Al chip badge */}
      <g transform="translate(60,55)">
        <rect x="-22" y="-12" width="44" height="24" rx="4" fill="#0F3D26"/>
        <text x="0" y="6" text-anchor="middle" font-size="12" font-weight="800" fill="#9CF5BF" font-family="Inter">Al · 22k</text>
      </g>
    </g>
  )}

  {item === 'paper' && (
    <g>
      {/* Newspaper / book stack */}
      <g transform="translate(80,80)">
        <rect x="0" y="0" width="240" height="20" fill="#FAFAF7" stroke="#7A5410" stroke-width="0.5"/>
        <line x1="10" y1="6" x2="230" y2="6" stroke="#7A5410" stroke-width="0.5" opacity="0.5"/>
        <line x1="10" y1="11" x2="200" y2="11" stroke="#7A5410" stroke-width="0.5" opacity="0.5"/>
        <line x1="10" y1="16" x2="220" y2="16" stroke="#7A5410" stroke-width="0.5" opacity="0.5"/>
        <text x="120" y="14" text-anchor="middle" font-size="9" font-weight="800" fill="#0F3D26" font-family="Inter">SÀI GÒN GIẢI PHÓNG</text>
      </g>
      {[28, 56, 84, 112, 140].map((y) => (
        <g transform={`translate(80, ${80 + y})`}>
          <rect x="0" y="0" width="240" height="22" fill="#E5EDDD" stroke="#7A5410" stroke-width="0.4"/>
          <line x1="10" y1="6" x2="230" y2="6" stroke="#7A5410" stroke-width="0.4" opacity="0.4"/>
          <line x1="10" y1="12" x2="220" y2="12" stroke="#7A5410" stroke-width="0.4" opacity="0.4"/>
          <line x1="10" y1="18" x2="200" y2="18" stroke="#7A5410" stroke-width="0.4" opacity="0.4"/>
        </g>
      ))}
      {/* String binding */}
      <g stroke="#0F3D26" stroke-width="1.5" fill="none" opacity="0.65">
        <path d="M120 70 Q120 130 120 240"/>
        <path d="M280 70 Q280 130 280 240"/>
      </g>
    </g>
  )}

  {/* ============== TIER B ============== */}
  {item === 'fridge' && (
    <g>
      <g transform="translate(150,50)">
        {/* shadow */}
        <ellipse cx="50" cy="220" rx="80" ry="10" fill="#0F1F18" opacity="0.20"/>
        {/* body */}
        <rect x="0" y="0" width="100" height="220" rx="6" fill="#FAFAF7" stroke="#7A5410" stroke-width="2"/>
        {/* upper door (freezer) */}
        <rect x="6" y="6" width="88" height="70" rx="4" fill="#E5EDDD"/>
        {/* lower door (fridge) */}
        <rect x="6" y="82" width="88" height="132" rx="4" fill="#FAFAF7"/>
        {/* divider */}
        <line x1="0" y1="78" x2="100" y2="78" stroke="#7A5410" stroke-width="2"/>
        {/* handles */}
        <rect x="78" y="32" width="6" height="22" rx="2" fill="#525C5A"/>
        <rect x="78" y="115" width="6" height="40" rx="2" fill="#525C5A"/>
        {/* energy label */}
        <rect x="20" y="170" width="34" height="34" rx="3" fill="#FFE066"/>
        <text x="37" y="185" text-anchor="middle" font-size="11" font-weight="800" fill="#0F3D26">A++</text>
        <text x="37" y="197" text-anchor="middle" font-size="6" fill="#0F3D26">300L</text>
        {/* brand */}
        <rect x="60" y="186" width="30" height="10" rx="1" fill="#0F3D26"/>
        <text x="75" y="193" text-anchor="middle" font-size="6" font-weight="800" fill="#9CF5BF" font-family="Inter">SAMSUNG</text>
      </g>
      {/* Snowflake icon */}
      <g transform="translate(70,90)" stroke="#3B8DD1" stroke-width="1.5" fill="none" opacity="0.7">
        <path d="M0 -10 L0 10 M-10 0 L10 0 M-7 -7 L7 7 M-7 7 L7 -7"/>
      </g>
    </g>
  )}

  {item === 'sofa' && (
    <g>
      <g transform="translate(50,100)">
        {/* shadow */}
        <ellipse cx="150" cy="170" rx="160" ry="12" fill="#0F1F18" opacity="0.20"/>
        {/* back rest */}
        <rect x="10" y="20" width="280" height="80" rx="14" fill="#A07033"/>
        <rect x="20" y="30" width="80" height="60" rx="10" fill="#7A5410"/>
        <rect x="110" y="30" width="80" height="60" rx="10" fill="#7A5410"/>
        <rect x="200" y="30" width="80" height="60" rx="10" fill="#7A5410"/>
        {/* seat */}
        <rect x="0" y="90" width="300" height="60" rx="14" fill="#C9A675"/>
        {/* cushions */}
        <rect x="10" y="100" width="90" height="42" rx="10" fill="#FFD960"/>
        <rect x="105" y="100" width="90" height="42" rx="10" fill="#FFD960"/>
        <rect x="200" y="100" width="90" height="42" rx="10" fill="#FFD960"/>
        {/* legs */}
        <rect x="20" y="148" width="8" height="16" fill="#5A3F1A"/>
        <rect x="272" y="148" width="8" height="16" fill="#5A3F1A"/>
      </g>
    </g>
  )}

  {item === 'tv' && (
    <g>
      <g transform="translate(80,60)">
        {/* shadow */}
        <ellipse cx="120" cy="200" rx="110" ry="10" fill="#0F1F18" opacity="0.20"/>
        {/* TV frame */}
        <rect x="0" y="0" width="240" height="160" rx="6" fill="#1F2A28"/>
        {/* screen */}
        <rect x="8" y="8" width="224" height="144" rx="3" fill="#3B8DD1"/>
        {/* gradient screen */}
        <rect x="8" y="8" width="224" height="80" rx="3" fill="#86B5D6"/>
        {/* sun on screen */}
        <circle cx="180" cy="55" r="22" fill="#FFE066"/>
        <circle cx="180" cy="55" r="14" fill="#FFD960"/>
        {/* mountains on screen */}
        <path d="M8 152 L60 100 L100 130 L160 80 L232 152 Z" fill="#0F6635"/>
        {/* logo */}
        <rect x="100" y="166" width="40" height="10" rx="2" fill="#0F3D26"/>
        <text x="120" y="174" text-anchor="middle" font-size="6" font-weight="800" fill="#9CF5BF" font-family="Inter">LCD 42"</text>
        {/* stand */}
        <path d="M90 176 L120 196 L150 176 Z" fill="#1F2A28"/>
        <rect x="60" y="195" width="120" height="6" rx="2" fill="#1F2A28"/>
      </g>
    </g>
  )}

  {item === 'washer' && (
    <g>
      <g transform="translate(140,55)">
        <ellipse cx="60" cy="220" rx="80" ry="10" fill="#0F1F18" opacity="0.20"/>
        <rect x="0" y="0" width="120" height="220" rx="6" fill="#FAFAF7" stroke="#7A5410" stroke-width="2"/>
        {/* control panel */}
        <rect x="0" y="0" width="120" height="36" rx="6" fill="#0F3D26"/>
        <text x="20" y="22" font-size="8" font-weight="800" fill="#9CF5BF" font-family="Inter">8 KG · INVERTER</text>
        <circle cx="100" cy="18" r="6" fill="#FFD960"/>
        {/* drum window (top loader) */}
        <rect x="14" y="50" width="92" height="60" rx="6" fill="#525C5A"/>
        <rect x="22" y="58" width="76" height="44" rx="3" fill="#9FA9A6"/>
        <text x="60" y="84" text-anchor="middle" font-size="11" font-weight="800" fill="#0F3D26">TOP LOAD</text>
        {/* settings panel */}
        <g transform="translate(30,130)">
          <circle cx="15" cy="15" r="14" fill="#E5EDDD" stroke="#7A5410" stroke-width="1.5"/>
          <line x1="15" y1="6" x2="15" y2="15" stroke="#0F3D26" stroke-width="2"/>
          <text x="15" y="46" text-anchor="middle" font-size="6" fill="#0F3D26">CYCLE</text>
          <circle cx="60" cy="15" r="14" fill="#E5EDDD" stroke="#7A5410" stroke-width="1.5"/>
          <line x1="60" y1="6" x2="68" y2="14" stroke="#0F3D26" stroke-width="2"/>
          <text x="60" y="46" text-anchor="middle" font-size="6" fill="#0F3D26">TEMP</text>
        </g>
        {/* feet */}
        <rect x="6" y="216" width="14" height="6" fill="#5A3F1A"/>
        <rect x="100" y="216" width="14" height="6" fill="#5A3F1A"/>
      </g>
      {/* water drop */}
      <g transform="translate(80,90)" fill="#3B8DD1">
        <path d="M0 0 Q-10 14 0 22 Q10 14 0 0 Z"/>
      </g>
    </g>
  )}

  {/* ============== TIER C ============== */}
  {item === 'mainboard' && (
    <g>
      <g transform="translate(60,80)">
        {/* PCB green board */}
        <rect x="0" y="0" width="280" height="160" rx="6" fill="#0F6635"/>
        {/* traces */}
        <g stroke="#9CF5BF" stroke-width="1" fill="none" opacity="0.75">
          <line x1="20" y1="20" x2="260" y2="20"/>
          <line x1="20" y1="35" x2="200" y2="35" stroke-dasharray="3 3"/>
          <line x1="60" y1="50" x2="220" y2="50"/>
          <line x1="20" y1="140" x2="260" y2="140"/>
          <path d="M20 80 L80 80 L80 100 L160 100 L160 80 L260 80"/>
        </g>
        {/* CPU socket */}
        <rect x="100" y="40" width="80" height="80" rx="3" fill="#1F2A28"/>
        <rect x="108" y="48" width="64" height="64" rx="2" fill="#A07033"/>
        <text x="140" y="84" text-anchor="middle" font-size="11" font-weight="800" fill="#FFD960" font-family="JetBrains Mono">CPU</text>
        {/* RAM slots */}
        <rect x="200" y="60" width="60" height="6" fill="#1F2A28"/>
        <rect x="200" y="72" width="60" height="6" fill="#1F2A28"/>
        <rect x="200" y="84" width="60" height="6" fill="#1F2A28"/>
        {/* capacitors */}
        <circle cx="40" cy="70" r="9" fill="#3B8DD1" stroke="#0F3D26" stroke-width="1"/>
        <text x="40" y="73" text-anchor="middle" font-size="7" fill="#FFD960" font-weight="800">C</text>
        <circle cx="60" cy="70" r="9" fill="#3B8DD1" stroke="#0F3D26" stroke-width="1"/>
        <text x="60" y="73" text-anchor="middle" font-size="7" fill="#FFD960" font-weight="800">C</text>
        <circle cx="80" cy="135" r="7" fill="#525C5A"/>
        <circle cx="100" cy="135" r="7" fill="#525C5A"/>
        {/* Cu pad */}
        <rect x="180" y="130" width="60" height="20" fill="#A07033"/>
        <text x="210" y="143" text-anchor="middle" font-size="8" font-weight="800" fill="#FFEFC8" font-family="Inter">Cu pad</text>
      </g>
    </g>
  )}

  {item === 'wire-cu' && (
    <g>
      <g transform="translate(80,90)">
        {/* coiled copper wire */}
        {[0, 1, 2, 3, 4, 5, 6].map((i) => (
          <ellipse cx={i * 4 + 20} cy={70 + (i % 2) * 4} rx={70 - i * 2} ry={50 - i * 2} fill="none" stroke="#A07033" stroke-width="6" opacity={0.7 + i * 0.04} />
        ))}
        {/* outer ring */}
        <ellipse cx="40" cy="70" rx="80" ry="58" fill="none" stroke="#5A3F1A" stroke-width="3"/>
        {/* center */}
        <ellipse cx="50" cy="70" rx="20" ry="14" fill="#7A5410"/>
        <ellipse cx="50" cy="70" rx="14" ry="10" fill="#3F2A0F"/>
        {/* highlight on top */}
        <ellipse cx="40" cy="35" rx="40" ry="6" fill="#FFEFC8" opacity="0.55"/>
      </g>
      {/* loose wire end */}
      <g transform="translate(220,140)">
        <path d="M0 0 Q40 -20 80 -10 Q120 0 140 -30" stroke="#A07033" stroke-width="6" fill="none" stroke-linecap="round"/>
        <path d="M0 0 Q40 -20 80 -10 Q120 0 140 -30" stroke="#FFD960" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.6"/>
      </g>
      {/* tag */}
      <g transform="translate(60,55)">
        <rect x="-30" y="-12" width="60" height="24" rx="4" fill="#0F3D26"/>
        <text x="0" y="5" text-anchor="middle" font-size="11" font-weight="800" fill="#FFD960" font-family="Inter">Cu 99%</text>
      </g>
    </g>
  )}

  {item === 'motor' && (
    <g>
      <g transform="translate(120,80)">
        {/* motor cylinder */}
        <ellipse cx="80" cy="80" rx="80" ry="18" fill="#525C5A"/>
        <rect x="0" y="40" width="160" height="80" fill="#525C5A"/>
        <ellipse cx="80" cy="40" rx="80" ry="18" fill="#9FA9A6"/>
        {/* fins */}
        {[0, 1, 2, 3, 4, 5].map((i) => (
          <line x1={i * 26 + 10} y1="44" x2={i * 26 + 10} y2="116" stroke="#1F2A28" stroke-width="2"/>
        ))}
        {/* shaft */}
        <rect x="-26" y="74" width="30" height="12" fill="#A07033"/>
        <ellipse cx="-26" cy="80" rx="3" ry="6" fill="#5A3F1A"/>
        {/* terminal box */}
        <rect x="60" y="-6" width="40" height="24" rx="3" fill="#0F3D26"/>
        <circle cx="72" cy="6" r="3" fill="#A07033"/>
        <circle cx="88" cy="6" r="3" fill="#A07033"/>
        {/* spec plate */}
        <rect x="50" y="60" width="60" height="32" rx="2" fill="#FFD960"/>
        <text x="80" y="73" text-anchor="middle" font-size="8" font-weight="800" fill="#0F3D26" font-family="JetBrains Mono">1 HP</text>
        <text x="80" y="85" text-anchor="middle" font-size="6" fill="#0F3D26" font-family="JetBrains Mono">220V/50Hz</text>
      </g>
    </g>
  )}

  {item === 'fan' && (
    <g>
      <g transform="translate(200,150)">
        {/* fan grille frame */}
        <circle r="80" fill="#1F2A28"/>
        <circle r="76" fill="none" stroke="#525C5A" stroke-width="2"/>
        <circle r="60" fill="none" stroke="#525C5A" stroke-width="1" opacity="0.6"/>
        <circle r="40" fill="none" stroke="#525C5A" stroke-width="1" opacity="0.6"/>
        {/* blades */}
        {[0, 90, 180, 270].map((rot) => (
          <path d={`M0 0 L 28 -8 Q 56 -20 60 -50 Q 44 -28 16 -10 Z`} fill="#9FA9A6" transform={`rotate(${rot})`}/>
        ))}
        {/* center hub */}
        <circle r="14" fill="#A07033"/>
        <circle r="10" fill="#FFD960"/>
        <circle r="4" fill="#0F3D26"/>
      </g>
      {/* base */}
      <rect x="180" y="225" width="40" height="40" rx="4" fill="#525C5A"/>
      <rect x="160" y="263" width="80" height="10" rx="3" fill="#1F2A28"/>
    </g>
  )}

  {/* ============== TIER H ============== */}
  {item === 'pin-aa' && (
    <g>
      {/* AA batteries lying down */}
      {[
        { y: 120, color: '#52E08D', label: 'GP' },
        { y: 150, color: '#3B8DD1', label: 'PANA' },
        { y: 180, color: '#E8758F', label: 'ENERG' },
        { y: 210, color: '#FFD960', label: 'AA 1.5V' },
      ].map((b) => (
        <g transform={`translate(80, ${b.y})`}>
          <ellipse cx="120" cy="14" rx="120" ry="3" fill="#0F1F18" opacity="0.18"/>
          {/* body */}
          <rect x="0" y="0" width="240" height="22" rx="2" fill={b.color}/>
          {/* + cap */}
          <rect x="240" y="4" width="10" height="14" rx="1" fill="#9FA9A6"/>
          <rect x="246" y="6" width="2" height="10" fill="#525C5A"/>
          <line x1="247" y1="11" x2="251" y2="11" stroke="#525C5A" stroke-width="1.5"/>
          {/* − cap */}
          <rect x="-4" y="4" width="6" height="14" rx="1" fill="#525C5A"/>
          {/* label */}
          <text x="120" y="14" text-anchor="middle" font-size="10" font-weight="800" fill="white" font-family="Inter">{b.label}</text>
          {/* highlight */}
          <rect x="0" y="2" width="240" height="3" fill="white" opacity="0.5"/>
        </g>
      ))}
      {/* hazard tag */}
      <g transform="translate(60,80)">
        <path d="M0 -22 L20 14 L-20 14 Z" fill="#FFE066" stroke="#0F3D26" stroke-width="2"/>
        <text x="0" y="9" text-anchor="middle" font-size="14" font-weight="800" fill="#0F3D26">!</text>
      </g>
    </g>
  )}

  {item === 'oil' && (
    <g>
      {/* Oil canister */}
      <g transform="translate(140,70)">
        {/* shadow */}
        <ellipse cx="60" cy="200" rx="80" ry="10" fill="#0F1F18" opacity="0.20"/>
        {/* body */}
        <rect x="0" y="20" width="120" height="180" rx="6" fill="#1F2A28"/>
        {/* highlight strip */}
        <rect x="6" y="26" width="14" height="168" fill="#525C5A" opacity="0.6"/>
        {/* label */}
        <rect x="20" y="60" width="84" height="100" fill="#FFD960"/>
        <text x="62" y="86" text-anchor="middle" font-size="11" font-weight="800" fill="#0F3D26" font-family="Inter">DẦU NHỚT</text>
        <text x="62" y="106" text-anchor="middle" font-size="9" font-weight="700" fill="#0F3D26" font-family="Inter">5W-30</text>
        <text x="62" y="124" text-anchor="middle" font-size="7" fill="#0F3D26" font-family="Inter">SAE Grade</text>
        <rect x="32" y="135" width="60" height="14" fill="#0F3D26"/>
        <text x="62" y="146" text-anchor="middle" font-size="9" font-weight="800" fill="#FFD960" font-family="JetBrains Mono">4 LÍT</text>
        {/* spout */}
        <rect x="40" y="0" width="20" height="20" fill="#525C5A"/>
        <rect x="36" y="-4" width="28" height="8" rx="2" fill="#1F2A28"/>
        {/* handle */}
        <path d="M70 20 Q90 30 90 60 L80 60 Q80 36 70 30 Z" fill="#1F2A28"/>
      </g>
      {/* warning */}
      <g transform="translate(70,90)">
        <path d="M0 -20 L18 12 L-18 12 Z" fill="#E8758F" stroke="#0F3D26" stroke-width="2"/>
        <text x="0" y="8" text-anchor="middle" font-size="14" font-weight="800" fill="white">⚠</text>
      </g>
    </g>
  )}

  {item === 'pin-li' && (
    <g>
      {/* Lithium battery (motorbike-style) */}
      <g transform="translate(100,80)">
        <ellipse cx="100" cy="160" rx="110" ry="10" fill="#0F1F18" opacity="0.20"/>
        <rect x="0" y="0" width="200" height="150" rx="8" fill="#1F2A28"/>
        {/* top with terminals */}
        <rect x="0" y="0" width="200" height="20" rx="6" fill="#0F3D26"/>
        {/* + terminal */}
        <rect x="20" y="-10" width="24" height="14" rx="2" fill="#A07033"/>
        <text x="32" y="0" text-anchor="middle" font-size="11" font-weight="800" fill="#FFE066">+</text>
        {/* − terminal */}
        <rect x="156" y="-10" width="24" height="14" rx="2" fill="#9FA9A6"/>
        <text x="168" y="0" text-anchor="middle" font-size="14" font-weight="800" fill="#1F2A28">−</text>
        {/* label */}
        <rect x="20" y="36" width="160" height="100" rx="3" fill="#52E08D"/>
        <text x="100" y="62" text-anchor="middle" font-size="14" font-weight="800" fill="#0F3D26" font-family="Inter">LITHIUM</text>
        <text x="100" y="84" text-anchor="middle" font-size="11" font-weight="700" fill="#0F3D26" font-family="Inter">12V · 9Ah</text>
        <text x="100" y="106" text-anchor="middle" font-size="9" fill="#0F3D26">Motorbike Battery</text>
        <rect x="40" y="116" width="120" height="14" fill="#0F3D26"/>
        <text x="100" y="127" text-anchor="middle" font-size="9" font-weight="800" fill="#9CF5BF" font-family="JetBrains Mono">Li-ion · Pb-Free</text>
      </g>
      {/* hazard */}
      <g transform="translate(60,90)">
        <path d="M0 -22 L22 16 L-22 16 Z" fill="#FFE066" stroke="#0F3D26" stroke-width="2"/>
        <text x="0" y="11" text-anchor="middle" font-size="14" font-weight="800" fill="#0F3D26">⚡</text>
      </g>
    </g>
  )}

  {item === 'bulb' && (
    <g>
      {/* Fluorescent bulbs cluster */}
      {[
        { x: 100, rot: -10, color: '#FAFAF7' },
        { x: 175, rot: 0, color: '#FFE066' },
        { x: 250, rot: 8, color: '#FAFAF7' },
      ].map((b) => (
        <g transform={`translate(${b.x},120) rotate(${b.rot})`}>
          {/* tube */}
          <rect x="-12" y="-60" width="24" height="120" rx="12" fill={b.color} stroke="#7A5410" stroke-width="1.5"/>
          {/* glow */}
          <rect x="-8" y="-55" width="16" height="110" rx="8" fill="#FFE066" opacity="0.55"/>
          {/* base */}
          <rect x="-14" y="-66" width="28" height="10" rx="3" fill="#525C5A"/>
          <rect x="-14" y="58" width="28" height="10" rx="3" fill="#525C5A"/>
          {/* pins */}
          <rect x="-6" y="68" width="3" height="6" fill="#9FA9A6"/>
          <rect x="3" y="68" width="3" height="6" fill="#9FA9A6"/>
          {/* label */}
          <text x="0" y="6" text-anchor="middle" font-size="8" font-weight="800" fill="#0F3D26" transform="rotate(90)">36W</text>
        </g>
      ))}
      {/* mercury hazard tag */}
      <g transform="translate(70,90)">
        <circle r="22" fill="#FFE066" stroke="#0F3D26" stroke-width="2"/>
        <text y="6" text-anchor="middle" font-size="20" font-weight="800" fill="#0F3D26">Hg</text>
      </g>
      {/* "TUBE 36W" tag */}
      <g transform="translate(330,80)">
        <rect x="-30" y="-12" width="60" height="24" rx="4" fill="#0F3D26"/>
        <text x="0" y="5" text-anchor="middle" font-size="10" font-weight="800" fill="#9CF5BF" font-family="Inter">36W · T8</text>
      </g>
    </g>
  )}
</svg>
