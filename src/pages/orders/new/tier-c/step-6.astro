---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import TopNav from '../../../../components/nav/TopNav.astro';
import OrderStepperBar from '../../../../components/order/OrderStepperBar.astro';
import StepHero from '../../../../components/order/StepHero.astro';
import { USER } from '../../../../lib/mock';

const steps = [
  { n: 1, label: 'Chụp ảnh', icon: 'photo_camera', href: '/orders/new/tier-c.html' },
  { n: 2, label: 'AI nhận diện', icon: 'smart_toy', href: '/orders/new/tier-c/step-2.html' },
  { n: 3, label: 'Dải BOM', icon: 'analytics', href: '/orders/new/tier-c/step-3.html' },
  { n: 4, label: 'Địa chỉ', icon: 'location_on', href: '/orders/new/tier-c/step-4.html' },
  { n: 5, label: 'Lịch hẹn', icon: 'schedule', href: '/orders/new/tier-c/step-5.html' },
  { n: 6, label: 'Xác nhận', icon: 'check_circle', href: '/orders/new/tier-c/step-6.html' },
];

const lowEst = 25_000, highEst = 60_000, advance = 60_000;
const summary = [
  { icon: 'developer_board', label: 'VẬT PHẨM', value: 'Mainboard PC ATX', sub: '~1.0 kg · vật phẩm hỗn hợp', bg: 'bg-clay-peach/40', border: 'border-tier-c/20', accent: 'text-tier-c' },
  { icon: 'pending_actions', label: 'TẠM ỨNG HOLD', value: `~${advance.toLocaleString('vi-VN')}đ`, sub: `Vào ví ảo ngay tại bàn cân · dải ${lowEst.toLocaleString('vi-VN')}–${highEst.toLocaleString('vi-VN')}đ`, bg: 'bg-clay-butter/40', border: 'border-amber-deep/20', accent: 'text-amber-deep', big: true },
  { icon: 'location_on', label: 'ĐỊA CHỈ', value: `${USER.address}, Q.7`, sub: 'Nhà riêng · chuông tầng 4', bg: 'bg-clay-sky/40', border: 'border-info/20', accent: 'text-info' },
  { icon: 'schedule', label: 'KHUNG GIỜ', value: 'Hôm nay · 14:00 — 16:00', sub: 'Giờ hành chính · Hub kịp rã xác cùng ngày', bg: 'bg-clay-sky/40', border: 'border-info/20', accent: 'text-info' },
];
const transparency = [
  { icon: 'fact_check', t: 'Peek-check tại nhà', d: 'Chống đánh tráo ruột' },
  { icon: 'route', t: 'Chuỗi hành trình mẫu', d: 'Chain of custody công khai' },
  { icon: 'scale', t: 'BOM thực do Hub rã xác', d: 'Đối chiếu trên app ≤ 24h' },
];
---

<BaseLayout title="Đặt đơn Tier C · Xác nhận — RE-LOOP">
  <TopNav active="orders" />

  <main class="pt-[100px] pb-space-96 min-h-screen">
    <div class="max-w-[1280px] mx-auto px-[80px]">
      <a href="/orders/new/tier-c/step-5.html" class="inline-flex items-center gap-space-8 font-mono-md text-[12px] text-text-secondary hover:text-tier-c font-semibold mb-space-16">
        <span class="material-symbols-rounded !text-[16px]">arrow_back</span>
        Bước 5 · Lịch hẹn
      </a>

      <OrderStepperBar steps={steps} activeStep={6} tierAccent="tier-c" />

      <StepHero
        eyebrow="Tier C · Bước 6/6 · Xác nhận"
        title="Tổng kết Tier C & xác nhận đặt đơn"
        subtitle="Tạm ứng HOLD ví ảo ngay sau cân · BOM thực + phần chênh ZaloPay trong 16-24h"
        accent="tier-c"
        illustration="milestone"
        chips={[
          { icon: 'pending_actions', label: 'HOLD', value: 'Ngay tại bàn cân', tone: 'peach' },
          { icon: 'price_check', label: 'Phần chênh', value: 'ZaloPay ≤ 24h', tone: 'butter' },
          { icon: 'support_agent', label: 'Hỗ trợ', value: '1900-RELOOP', tone: 'mint' },
        ]}
      />

      <div class="grid grid-cols-[2fr_1fr] gap-space-32">
        <div class="flex flex-col gap-space-24">
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-c font-semibold flex items-center gap-space-8 mb-space-16"><span class="material-symbols-rounded fill !text-[16px]">receipt_long</span>TÓM TẮT ĐƠN</span>
            <div class="grid grid-cols-2 gap-space-16">
              {summary.map((s) => (
                <div class:list={['rounded-2xl p-space-20 border text-col', s.bg, s.border]}>
                  <div class="flex items-center gap-space-12 mb-space-12"><span class:list={['material-symbols-rounded fill !text-[20px]', s.accent]}>{s.icon}</span><span class:list={['font-mono-md text-[10px] uppercase tracking-wider font-bold', s.accent]}>{s.label}</span></div>
                  {s.big ? <span class="font-display font-extrabold text-[24px] text-text-primary tabular-nums block">{s.value}</span> : <span class="font-display font-bold text-[14px] text-text-primary block">{s.value}</span>}
                  <span class="font-mono-md text-[11px] text-text-tertiary mt-space-4 block">{s.sub}</span>
                </div>
              ))}
            </div>
          </section>

          <section class="bg-bg-elevated rounded-[28px] shadow-clay-sm border border-border-subtle p-space-32">
            <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-c font-semibold flex items-center gap-space-8 mb-space-12"><span class="material-symbols-rounded fill !text-[16px]">account_balance_wallet</span>DÒNG TIỀN TIER C</span>
            <div class="bg-clay-butter/40 border border-amber-deep/20 rounded-2xl p-space-20 flex items-center gap-space-16">
              <div class="w-12 h-12 rounded-2xl bg-bg-elevated flex items-center justify-center shadow-clay-sm shrink-0"><span class="material-symbols-rounded fill !text-[24px] text-amber-deep">lock</span></div>
              <div class="flex-1 text-col"><span class="font-display font-bold text-[14px] text-text-primary block">Tạm ứng ~{advance.toLocaleString('vi-VN')}đ HOLD trong ví ảo</span><p class="font-body-md text-[12px] text-text-secondary mt-space-4">Chưa rút được. Sau Hub rã xác + mass-balance ≥ 90% → phần chênh tự động về ZaloPay 0901-***-456 (nếu BOM thực cao hơn). BOM thấp hơn → giữ nguyên tạm ứng.</p></div>
            </div>
            <label class="flex items-start gap-space-12 cursor-pointer mt-space-16 p-space-16 bg-clay-peach/40 border border-tier-c/20 rounded-2xl">
              <input type="checkbox" checked class="mt-space-4 w-5 h-5 accent-tier-c shrink-0" />
              <div class="flex-1 text-col"><span class="font-display font-bold text-[13px] text-text-primary block">Tôi đồng ý điều khoản Tier C</span><p class="font-body-md text-[12px] text-text-secondary mt-space-4">Chấp nhận giá chốt theo BOM thực do Hub rã xác · chuỗi hành trình mẫu công khai · <a href="/wallet/policy.html" class="text-tier-c font-bold hover:underline">Quy định BOM</a></p></div>
            </label>
          </section>
        </div>

        <div class="flex flex-col gap-space-16">
          <div class="bg-clay-peach rounded-[24px] shadow-clay border-2 border-tier-c/30 p-space-24 relative overflow-hidden">
            <svg class="absolute top-space-12 right-space-16 w-7 h-7" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="4" fill="#E68A3F" opacity="0.4" /></svg>
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-c font-bold block">TỔNG KẾT THANH TOÁN</span>
            <div class="mt-space-12"><span class="font-mono-md text-[10px] text-text-tertiary uppercase tracking-wider">Tạm ứng HOLD (theo Trust)</span><span class="font-display font-extrabold text-[36px] text-amber-deep tabular-nums leading-none mt-space-4 block">~{advance.toLocaleString('vi-VN')}đ</span></div>
            <div class="mt-space-12 p-space-12 bg-bg-elevated/60 rounded-2xl flex items-center justify-between"><span class="font-mono-md text-[11px] text-text-tertiary uppercase tracking-wider font-semibold">Dải BOM kỳ vọng</span><span class="font-mono-md text-[12px] text-tier-c font-bold tabular-nums">{lowEst.toLocaleString('vi-VN')}–{highEst.toLocaleString('vi-VN')}đ</span></div>
            <div class="mt-space-8 p-space-12 bg-bg-elevated/60 rounded-2xl flex items-center justify-between"><span class="font-mono-md text-[11px] text-text-tertiary uppercase tracking-wider font-semibold">Reward</span><span class="font-mono-md text-[12px] text-tier-s font-bold">+8 GP · −3kg CO₂</span></div>
          </div>

          <a href="/orders/new/tier-c/success.html" class="bg-tier-c text-white py-space-16 rounded-2xl font-bold shadow-clay text-[16px] inline-flex items-center justify-center gap-space-8 hover:-translate-y-[2px] transition">
            <span class="material-symbols-rounded fill !text-[22px]">check_circle</span>
            Xác nhận đặt đơn
          </a>
          <button class="bg-bg-elevated text-text-primary border border-border-subtle py-space-12 rounded-2xl font-mono-md text-[12px] font-bold shadow-clay-sm hover:shadow-clay">Lưu nháp · Đặt sau</button>

          <div class="bg-clay-sky/40 rounded-[24px] shadow-clay-sm border border-info/20 p-space-24">
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-info font-bold flex items-center gap-space-8 mb-space-12"><span class="material-symbols-rounded fill !text-[14px]">shield</span>MINH BẠCH TIER C</span>
            <div class="flex flex-col gap-space-8">
              {transparency.map((t) => (
                <div class="flex items-center gap-space-12 p-space-12 bg-bg-elevated/70 rounded-xl">
                  <div class="w-8 h-8 rounded-xl bg-clay-sky flex items-center justify-center shadow-clay-sm shrink-0"><span class="material-symbols-rounded fill !text-[16px] text-info">{t.icon}</span></div>
                  <div class="flex-1 text-col"><span class="font-display font-bold text-[12px] text-text-primary block">{t.t}</span><span class="font-mono-md text-[10px] text-text-tertiary block">{t.d}</span></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
