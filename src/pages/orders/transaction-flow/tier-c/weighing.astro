---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import TopNav from '../../../../components/nav/TopNav.astro';
import StepHero from '../../../../components/order/StepHero.astro';
import TxnSidebar from '../../../../components/order/TxnSidebar.astro';

const stepsTC = (active: number) => ['Cân tại nhà', 'Hiện khối lượng', 'Peek-check', 'HOLD ví ảo', 'OTP bàn giao', 'Hoàn tất'].map((label, i) => ({ label, state: (i + 1 < active ? 'done' : i + 1 === active ? 'active' : 'pending') as 'done' | 'active' | 'pending' }));
const recording = [
  { icon: 'monitor_weight', t: 'Khối lượng thực', d: 'Đọc từ cân điện tử', done: true },
  { icon: 'photo_camera', t: 'Ảnh evidence', d: '3 góc + cận mặt cân', done: true },
  { icon: 'schedule', t: 'Mốc thời gian', d: 'Đóng dấu vào log đơn', done: true },
  { icon: 'qr_code_2', t: 'Niêm phong túi mã QR', d: 'QR gắn mã đơn RL-…1240', done: false },
];
const collectorSteps = [
  { icon: 'inventory_2', t: 'Đặt vật phẩm lên cân', done: true },
  { icon: 'pending', t: 'Chờ số ổn định', done: false },
  { icon: 'photo_camera', t: 'Chụp ảnh tự động', done: false },
  { icon: 'cloud_upload', t: 'Đồng bộ lên app', done: false },
];
---

<BaseLayout title="Cân tại nhà · Tier C · Đang cân — RE-LOOP">
  <TopNav active="orders" />
  <main class="pt-[100px] pb-space-96 min-h-screen">
    <div class="max-w-[1280px] mx-auto px-[80px]">
      <a href="/orders/RL-2026-001240.html" class="inline-flex items-center gap-space-8 font-mono-md text-[12px] text-text-secondary hover:text-tier-c font-semibold mb-space-16">
        <span class="material-symbols-rounded !text-[16px]">arrow_back</span>
        Về chi tiết đơn
      </a>

      <StepHero
        eyebrow="Tier C · Giao dịch 1/6 · Đang cân"
        title="Chị Hoa đang cân vật phẩm hỗn hợp"
        subtitle="Cân chuẩn QTĐLVN 252 · bao bọc niêm phong túi mã QR để chuyển Hub rã xác"
        accent="tier-c"
        illustration="recycle"
        chips={[
          { icon: 'scale', label: 'Cân chuẩn', value: 'QTĐLVN 252', tone: 'peach' },
          { icon: 'inventory_2', label: 'Niêm phong', value: 'Túi mã QR', tone: 'butter' },
          { icon: 'photo_camera', label: 'Ghi nhận', value: 'Tự động', tone: 'peach' },
        ]}
      />

      <div class="grid grid-cols-[2fr_1fr] gap-space-32">
        <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-40 flex flex-col gap-space-24 relative overflow-hidden">
          <svg class="absolute top-space-24 left-space-32 w-7 h-7" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="4" fill="#E68A3F" opacity="0.4" /></svg>
          <svg class="absolute bottom-space-24 right-space-32 w-9 h-9" viewBox="0 0 36 36" fill="none"><path d="M18 4l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6z" fill="#E68A3F" opacity="0.3" /></svg>

          <div class="flex items-center gap-space-12 relative">
            <div class="relative w-14 h-14 shrink-0">
              <div class="absolute inset-0 rounded-2xl bg-tier-c/15 animate-ping"></div>
              <div class="relative w-full h-full rounded-2xl bg-clay-peach flex items-center justify-center shadow-clay-sm"><span class="material-symbols-rounded fill text-tier-c animate-spin !text-[28px]" style="animation-duration:1.6s">scale</span></div>
            </div>
            <div class="flex-1 text-col">
              <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-c font-bold">ĐANG CÂN TẠI NHÀ</span>
              <h2 class="font-h2 text-h2 text-text-primary">Chị Hoa đang cân vật phẩm</h2>
            </div>
            <span class="px-space-12 py-[5px] rounded-full bg-clay-peach border border-tier-c/30 font-mono-md text-[10px] text-tier-c font-bold uppercase tracking-wider flex items-center gap-space-4 shrink-0"><span class="w-[6px] h-[6px] rounded-full bg-tier-c animate-pulse"></span>Live</span>
          </div>

          <!-- Digital scale display -->
          <div class="bg-forest rounded-[24px] p-space-32 shadow-clay relative overflow-hidden">
            <div class="absolute inset-0 opacity-[0.08]" style="background-image:radial-gradient(circle,#E68A3F 1px,transparent 1px);background-size:14px 14px"></div>
            <div class="relative flex items-end justify-between gap-space-16">
              <div class="flex flex-col gap-space-4">
                <span class="font-mono-md text-[10px] uppercase tracking-[0.2em] text-clay-peach font-bold">SMART SCALE · QTĐLVN 252</span>
                <span class="font-mono-md text-[11px] text-white/50">Vật phẩm hỗn hợp · niêm phong túi QR</span>
              </div>
              <span class="font-mono-md text-[11px] text-clay-peach/80 font-semibold flex items-center gap-space-4"><span class="material-symbols-rounded !text-[14px]">bluetooth_connected</span>Đồng bộ…</span>
            </div>
            <div class="relative mt-space-20 flex items-baseline justify-center gap-space-8">
              <span class="font-display font-extrabold text-[76px] text-clay-peach tabular-nums leading-none" style="text-shadow:0 0 26px rgba(230,138,63,0.5)">~1.0</span>
              <span class="font-mono-md text-[22px] text-clay-peach/60 font-bold">kg</span>
            </div>
            <div class="relative mt-space-20 h-[6px] rounded-full bg-white/10 overflow-hidden"><div class="h-full rounded-full bg-tier-c animate-pulse" style="width:58%"></div></div>
            <p class="relative mt-space-12 font-mono-md text-[11px] text-white/50 text-center">Chờ số ổn định… Mainboard PC ATX · giá thực chốt sau Hub rã xác</p>
          </div>

          <!-- Collector mini-steps -->
          <div class="flex items-center gap-space-8">
            {collectorSteps.map((s, i) => (
              <>
                <div class:list={['flex-1 flex flex-col items-center gap-space-8 text-center', s.done ? '' : 'opacity-55']}>
                  <div class:list={['w-9 h-9 rounded-xl flex items-center justify-center shadow-clay-sm', s.done ? 'bg-tier-c text-white' : (i === 1 ? 'bg-clay-peach text-tier-c animate-pulse' : 'bg-bg-base text-text-tertiary')]}><span class="material-symbols-rounded fill !text-[16px]">{s.done ? 'check' : s.icon}</span></div>
                  <span class="font-mono-md text-[10px] text-text-secondary leading-tight">{s.t}</span>
                </div>
                {i < collectorSteps.length - 1 && <span class:list={['material-symbols-rounded !text-[14px] -mt-space-16', s.done ? 'text-tier-c' : 'text-border-default']}>arrow_forward</span>}
              </>
            ))}
          </div>

          <!-- Recording checklist -->
          <div>
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-text-tertiary font-bold flex items-center gap-space-8 mb-space-12"><span class="material-symbols-rounded fill !text-[14px] text-tier-c">checklist</span>ĐANG GHI NHẬN VÀO LOG ĐƠN</span>
            <div class="grid grid-cols-2 gap-space-12">
              {recording.map((r) => (
                <div class:list={['flex items-start gap-space-12 p-space-12 rounded-2xl border-2 shadow-clay-sm', r.done ? 'bg-clay-peach border-tier-c/30' : 'bg-bg-base/50 border-border-subtle']}>
                  <div class:list={['w-8 h-8 rounded-xl flex items-center justify-center shadow-clay-sm shrink-0', r.done ? 'bg-tier-c text-white' : 'bg-bg-elevated text-text-tertiary']}><span class="material-symbols-rounded fill !text-[16px]">{r.done ? 'check' : r.icon}</span></div>
                  <div class="flex-1 text-col"><span class="font-display font-bold text-[12px] text-text-primary block">{r.t}</span><span class="font-mono-md text-[10px] text-text-tertiary block mt-[2px]">{r.d}</span></div>
                </div>
              ))}
            </div>
          </div>

          <a href="/orders/transaction-flow/tier-c/weight-reveal.html" class="self-center px-space-32 py-[14px] rounded-2xl bg-tier-c text-white font-semibold text-[14px] shadow-clay hover:-translate-y-[2px] transition inline-flex items-center gap-space-8">Xem khối lượng thực<span class="material-symbols-rounded !text-[18px]">arrow_forward</span></a>
        </section>

        <TxnSidebar
          collectorName="Chị Hoa" collectorAvatar="H" collectorTierLabel="Tier 2 · Hub Q.7 · Verified Tier C" collectorRating={4.9} collectorVehicle="Xe ba gác · 51B-67890"
          itemName="Mainboard PC ATX" itemHint="~1.0 kg · vật phẩm hỗn hợp" itemIcon="developer_board"
          accent="tier-c" avatarGradient="from-clay-peach to-tier-c" itemClay="bg-clay-peach"
          subSteps={stepsTC(1)}
        >
          <div class="bg-clay-peach rounded-[24px] shadow-clay-sm border-2 border-tier-c/30 p-space-20">
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-c font-bold flex items-center gap-space-8 mb-space-12"><span class="material-symbols-rounded fill !text-[14px]">route</span>SAU KHI CÂN</span>
            <div class="flex flex-col gap-space-8">
              <div class="flex items-center gap-space-12 p-space-12 bg-bg-elevated/70 rounded-xl"><div class="w-8 h-8 rounded-xl bg-clay-peach flex items-center justify-center shadow-clay-sm shrink-0"><span class="material-symbols-rounded fill !text-[16px] text-tier-c">policy</span></div><div class="flex-1 text-col"><span class="font-display font-bold text-[12px] text-text-primary block">Peek-check chống fraud</span><span class="font-mono-md text-[10px] text-text-tertiary">Verify không tráo ruột (Trust &lt; 50)</span></div></div>
              <div class="flex items-center gap-space-12 p-space-12 bg-bg-elevated/70 rounded-xl"><div class="w-8 h-8 rounded-xl bg-clay-butter flex items-center justify-center shadow-clay-sm shrink-0"><span class="material-symbols-rounded fill !text-[16px] text-amber-deep">pending_actions</span></div><div class="flex-1 text-col"><span class="font-display font-bold text-[12px] text-text-primary block">Tạm ứng HOLD ví ảo</span><span class="font-mono-md text-[10px] text-text-tertiary">Theo Trust Score · auto-release sau verify</span></div></div>
              <div class="flex items-center gap-space-12 p-space-12 bg-bg-elevated/70 rounded-xl"><div class="w-8 h-8 rounded-xl bg-clay-peach flex items-center justify-center shadow-clay-sm shrink-0"><span class="material-symbols-rounded fill !text-[16px] text-tier-c">precision_manufacturing</span></div><div class="flex-1 text-col"><span class="font-display font-bold text-[12px] text-text-primary block">Hub rã xác → BOM thực</span><span class="font-mono-md text-[10px] text-text-tertiary">16–24h · phần chênh về ZaloPay</span></div></div>
            </div>
          </div>
        </TxnSidebar>
      </div>
    </div>
  </main>
</BaseLayout>
