---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNav from '../../components/nav/TopNav.astro';
import DisputeScene from '../../components/illustrations/DisputeScene.astro';
import { ORDERS } from '../../lib/mock';

const eligibleOrders = ORDERS.filter((o) => o.status === 'COMPLETED' || o.status === 'PENDING_VERIFY');

const disputeTypes = [
  { id: 'BOM_DISPUTE', label: 'BOM thực không khớp', desc: 'Khối lượng vật liệu sau Hub rã xác thấp hơn kỳ vọng', icon: 'fact_check', clay: 'bg-clay-butter', accent: 'text-amber-deep' },
  { id: 'WEIGHT_MISMATCH', label: 'Cân tại nhà sai', desc: 'Cân điện tử hiển thị khác kết quả cuối', icon: 'scale', clay: 'bg-clay-sky', accent: 'text-info' },
  { id: 'COLLECTOR_BEHAVIOR', label: 'Hành vi Collector', desc: 'Trễ hẹn không thông báo, thái độ thiếu tôn trọng', icon: 'person_off', clay: 'bg-clay-blush', accent: 'text-tier-h' },
  { id: 'PRICE_MISMATCH', label: 'Giá tính sai', desc: 'Giá hiển thị khác đơn giá Tier S đã công bố', icon: 'paid', clay: 'bg-clay-peach', accent: 'text-tier-c' },
];
---

<BaseLayout title="Tạo tranh chấp mới — RE-LOOP">
  <TopNav active="orders" />

  <main class="pt-[100px] pb-space-96 min-h-screen">
    <div class="max-w-[1280px] mx-auto px-[80px]">
      <a href="/disputes.html" class="inline-flex items-center gap-space-8 font-mono-md text-[12px] text-text-secondary hover:text-tier-s font-semibold mb-space-16">
        <span class="material-symbols-rounded !text-[16px]">arrow_back</span>
        Tranh chấp
      </a>

      <!-- Hero -->
      <section class="grad-hero rounded-[40px] px-space-48 py-space-32 border border-border-subtle mb-space-32 relative overflow-hidden">
        <div class="grid grid-cols-[1.4fr_1fr] gap-space-32 items-center">
          <div class="relative z-10">
            <span class="font-mono-md text-[11px] uppercase tracking-[0.2em] text-amber-deep font-bold bg-clay-butter border-2 border-amber-deep/30 rounded-full px-space-12 py-[4px] inline-flex items-center gap-space-8 shadow-clay-sm mb-space-12">
              <span class="material-symbols-rounded fill !text-[14px]">add_comment</span>
              TẠO TRANH CHẤP MỚI
            </span>
            <h1 class="font-display-l text-[44px] font-extrabold leading-[1.05] tracking-tight text-text-primary mb-space-12">Bạn cần khiếu nại điều gì?</h1>
            <p class="font-body-lg text-body-lg text-text-secondary mb-space-16">
              CS phản hồi trong 24h · Đính kèm ảnh/video evidence để tăng cơ hội thắng · Win rate trung bình 23%
            </p>
            <div class="flex flex-wrap gap-space-12">
              <div class="bg-clay-mint border-2 border-tier-s/30 rounded-2xl px-space-16 py-space-12 shadow-clay-sm flex items-center gap-space-12">
                <span class="material-symbols-rounded fill !text-[24px] text-tier-s">photo_camera</span>
                <div class="flex flex-col">
                  <span class="font-mono-md text-[10px] text-tier-s uppercase tracking-wider font-semibold">Evidence quyết định</span>
                  <span class="font-mono-md text-[13px] text-text-primary font-bold">78% kết quả</span>
                </div>
              </div>
              <div class="bg-clay-sky border-2 border-info/30 rounded-2xl px-space-16 py-space-12 shadow-clay-sm flex items-center gap-space-12">
                <span class="material-symbols-rounded fill !text-[24px] text-info">schedule</span>
                <div class="flex flex-col">
                  <span class="font-mono-md text-[10px] text-info uppercase tracking-wider font-semibold">Thời hạn gửi</span>
                  <span class="font-mono-md text-[13px] text-text-primary font-bold">48h sau Hub verify</span>
                </div>
              </div>
            </div>
          </div>
          <div class="relative h-[260px]">
            <DisputeScene class="absolute inset-0 w-full h-full" />
          </div>
        </div>
      </section>

      <!-- Form -->
      <div class="grid grid-cols-[2fr_1fr] gap-space-32">
        <!-- Left col: form -->
        <div class="flex flex-col gap-space-24">
          <!-- Step 1: Pick order -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <div class="flex items-center gap-space-12 mb-space-16">
              <div class="w-10 h-10 rounded-2xl bg-clay-mint flex items-center justify-center shadow-clay-sm">
                <span class="font-display font-extrabold text-[16px] text-tier-s">1</span>
              </div>
              <div>
                <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-s font-semibold">BƯỚC 1</span>
                <h3 class="font-h3 text-h3 text-text-primary">Chọn đơn liên quan</h3>
              </div>
            </div>
            <div class="grid grid-cols-1 gap-space-12">
              {eligibleOrders.slice(0, 4).map((o, i) => (
                <label class:list={['flex items-center gap-space-16 p-space-16 rounded-2xl border-2 cursor-pointer transition shadow-clay-sm hover:shadow-clay', i === 0 ? 'bg-clay-mint border-tier-s' : 'bg-bg-surface border-border-subtle hover:border-border-default']}>
                  <input type="radio" name="order" checked={i === 0} class="w-5 h-5 accent-tier-s shrink-0" />
                  <div class:list={['w-10 h-10 rounded-2xl flex items-center justify-center shadow-clay-sm', o.tier === 'S' ? 'bg-clay-mint text-tier-s' : 'bg-clay-peach text-tier-c']}>
                    <span class="font-display font-extrabold text-[14px]">{o.tier}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <span class="font-display font-bold text-[14px] text-text-primary block truncate">{o.item}</span>
                    <span class="font-mono-md text-[11px] text-text-tertiary">{o.id} · {o.weight}kg</span>
                  </div>
                  <span class="font-mono-md text-[12px] text-text-secondary tabular-nums">{(o.amount ?? o.advance ?? 0).toLocaleString('vi-VN')}đ</span>
                </label>
              ))}
            </div>
          </section>

          <!-- Step 2: Type -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <div class="flex items-center gap-space-12 mb-space-16">
              <div class="w-10 h-10 rounded-2xl bg-clay-mint flex items-center justify-center shadow-clay-sm">
                <span class="font-display font-extrabold text-[16px] text-tier-s">2</span>
              </div>
              <div>
                <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-s font-semibold">BƯỚC 2</span>
                <h3 class="font-h3 text-h3 text-text-primary">Loại tranh chấp</h3>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-space-12">
              {disputeTypes.map((t, i) => (
                <label class:list={['flex items-start gap-space-12 p-space-16 rounded-2xl border-2 cursor-pointer transition shadow-clay-sm hover:shadow-clay', i === 0 ? `${t.clay} border-${t.accent.replace('text-', '')}` : 'bg-bg-surface border-border-subtle']}>
                  <input type="radio" name="type" checked={i === 0} class="w-5 h-5 mt-space-4 accent-tier-s shrink-0" />
                  <div class="flex-1">
                    <div class:list={['w-10 h-10 rounded-2xl bg-bg-elevated flex items-center justify-center shadow-clay-sm mb-space-8']}>
                      <span class:list={['material-symbols-rounded fill !text-[20px]', t.accent]}>{t.icon}</span>
                    </div>
                    <span class="font-display font-bold text-[13px] text-text-primary block">{t.label}</span>
                    <span class="font-body-md text-[11px] text-text-secondary mt-space-4 block">{t.desc}</span>
                  </div>
                </label>
              ))}
            </div>
          </section>

          <!-- Step 3: Description -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <div class="flex items-center gap-space-12 mb-space-16">
              <div class="w-10 h-10 rounded-2xl bg-clay-mint flex items-center justify-center shadow-clay-sm">
                <span class="font-display font-extrabold text-[16px] text-tier-s">3</span>
              </div>
              <div>
                <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-s font-semibold">BƯỚC 3</span>
                <h3 class="font-h3 text-h3 text-text-primary">Mô tả chi tiết</h3>
              </div>
            </div>
            <div class="bg-bg-surface rounded-2xl border-2 border-border-subtle p-space-16 mb-space-12 shadow-inset-soft min-h-[128px]">
              <p class="font-body-md text-[14px] text-text-tertiary leading-relaxed">Mô tả chi tiết: BOM thực thiếu vật liệu nào, cân sai khoảng bao nhiêu, hành vi cụ thể của collector…</p>
            </div>
            <div class="flex items-center justify-between">
              <span class="font-mono-md text-[11px] text-text-tertiary">Tối thiểu 50 ký tự · Mô tả càng chi tiết càng tăng cơ hội thắng</span>
              <span class="font-mono-md text-[11px] text-text-tertiary tabular-nums">0 / 1000</span>
            </div>
          </section>

          <!-- Step 4: Evidence upload -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <div class="flex items-center gap-space-12 mb-space-16">
              <div class="w-10 h-10 rounded-2xl bg-clay-mint flex items-center justify-center shadow-clay-sm">
                <span class="font-display font-extrabold text-[16px] text-tier-s">4</span>
              </div>
              <div>
                <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-s font-semibold">BƯỚC 4</span>
                <h3 class="font-h3 text-h3 text-text-primary">Đính kèm evidence</h3>
              </div>
            </div>
            <div class="grid grid-cols-4 gap-space-12 mb-space-12">
              {[1, 2, 3].map((i) => (
                <div class="h-[140px] rounded-2xl bg-clay-mint border-2 border-tier-s/30 shadow-clay-sm overflow-hidden flex flex-col items-center justify-center gap-space-8">
                  <span class="material-symbols-rounded fill !text-[28px] text-tier-s">image</span>
                  <span class="font-mono-md text-[10px] text-tier-s font-bold">Ảnh {i}.jpg</span>
                </div>
              ))}
              <button class="h-[140px] rounded-2xl bg-bg-surface border-2 border-dashed border-border-default shadow-clay-sm flex flex-col items-center justify-center gap-space-8 hover:border-tier-s hover:bg-clay-mint/40 transition">
                <span class="material-symbols-rounded !text-[28px] text-text-tertiary">add_photo_alternate</span>
                <span class="font-mono-md text-[10px] text-text-tertiary font-semibold">Thêm</span>
              </button>
            </div>
            <div class="flex items-center gap-space-12 p-space-12 bg-clay-butter rounded-2xl border border-amber-deep/20">
              <span class="material-symbols-rounded fill !text-[20px] text-amber-deep shrink-0">tips_and_updates</span>
              <p class="font-body-md text-[12px] text-text-secondary">
                <strong class="text-text-primary">Mẹo:</strong> Ảnh trước khi niêm phong + video lúc cân + ghi âm trao đổi với collector tăng win rate lên ~78%.
              </p>
            </div>
          </section>

          <!-- Submit -->
          <div class="flex gap-space-12">
            <button class="flex-1 bg-text-primary text-white py-space-16 rounded-2xl font-semibold shadow-clay text-[15px] inline-flex items-center justify-center gap-space-8 hover:-translate-y-[2px] transition">
              <span class="material-symbols-rounded fill !text-[20px]">send</span>
              Gửi tranh chấp
            </button>
            <a href="/disputes.html" class="bg-bg-elevated text-text-primary border border-border-subtle px-space-32 py-space-16 rounded-2xl font-semibold shadow-clay-sm text-[15px] inline-flex items-center gap-space-8 hover:shadow-clay">
              Hủy
            </a>
          </div>
        </div>

        <!-- Right col: sidebar info -->
        <div class="flex flex-col gap-space-16">
          <div class="bg-clay-mint rounded-[24px] shadow-clay-sm border-2 border-tier-s/30 p-space-24 flex flex-col gap-space-12">
            <span class="material-symbols-rounded fill !text-[32px] text-tier-s">verified_user</span>
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-s font-bold">CAM KẾT MINH BẠCH</span>
            <h4 class="font-h3 text-h3 text-text-primary">Thắng dispute = hoàn 100%</h4>
            <p class="font-body-md text-[13px] text-text-secondary">Nếu RE-LOOP audit và kết luận bạn đúng, bạn nhận lại 100% chênh + 100 GP đền bù.</p>
          </div>

          <div class="bg-bg-elevated rounded-[24px] shadow-clay-sm border border-border-subtle p-space-24">
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-s font-bold block mb-space-12">QUY TRÌNH 4 BƯỚC</span>
            <ol class="flex flex-col gap-space-12">
              {[
                { n: 1, label: 'Bạn gửi → CS confirm trong 4h' },
                { n: 2, label: 'CS audit log + ảnh evidence' },
                { n: 3, label: 'Quyết định trong 24h' },
                { n: 4, label: 'Hoàn tiền + GP nếu thắng' },
              ].map((s) => (
                <li class="flex items-start gap-space-8">
                  <span class="w-6 h-6 rounded-full bg-clay-mint border border-tier-s/40 flex items-center justify-center font-mono-md text-[11px] text-tier-s font-extrabold shrink-0">{s.n}</span>
                  <span class="font-body-md text-[13px] text-text-secondary">{s.label}</span>
                </li>
              ))}
            </ol>
          </div>

          <a href="/help.html" class="bg-clay-sky rounded-[24px] shadow-clay-sm border-2 border-info/30 p-space-24 flex items-center gap-space-12 hover:shadow-clay transition">
            <span class="material-symbols-rounded fill !text-[28px] text-info">support_agent</span>
            <div class="flex-1">
              <span class="font-mono-md text-[11px] text-info uppercase tracking-wider font-bold block">Cần tư vấn trước?</span>
              <span class="font-display font-bold text-[14px] text-text-primary">Hotline 1900-RELOOP</span>
            </div>
            <span class="material-symbols-rounded !text-[18px] text-info">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
