---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/nav/TopNav.astro';
import TrustScoreGauge from '../components/profile/TrustScoreGauge.astro';
import { USER, STATS } from '../lib/mock';
import { formatDate } from '../lib/format';

const milestones = [
  { range: '0-20', label: 'User mới', advance: '30%', color: 'error' },
  { range: '20-80', label: 'Đang tích lũy', advance: '50%', color: 'warning', current: true },
  { range: '80+', label: 'Đáng tin', advance: '70%', color: 'success' },
];
---

<BaseLayout title="Hồ sơ — RE-LOOP">
  <TopNav active="profile" />

  <main class="pt-32 pb-space-96 min-h-screen">
    <div class="max-w-[1280px] mx-auto px-[80px] flex flex-col gap-space-32">
      <h1 class="font-h1 text-h1 text-text-primary">Hồ sơ của tôi</h1>

      <div class="grid grid-cols-12 gap-space-32">
        <!-- Trust Score gauge -->
        <div class="col-span-5 bg-bg-elevated border border-border-subtle rounded-3xl p-space-48 flex flex-col items-center gap-space-24">
          <TrustScoreGauge score={USER.trustScore} />
          <p class="font-body-md text-[13px] text-text-secondary text-center max-w-[320px]">
            Trust Score tăng theo lịch sử đơn hàng thành công. Score cao hơn → tỷ lệ tạm ứng Tier C cao hơn.
          </p>
        </div>

        <!-- Milestones + profile -->
        <div class="col-span-7 flex flex-col gap-space-24">
          <!-- Progression milestones -->
          <div class="bg-bg-elevated border border-border-subtle rounded-3xl p-space-32">
            <h3 class="font-h4 text-h4 text-text-primary mb-space-16">Trust Score progression</h3>
            <div class="flex flex-col gap-space-12">
              {milestones.map((m) => (
                <div class:list={[
                  'flex items-center justify-between p-space-16 rounded-xl border',
                  m.current
                    ? m.color === 'warning' ? 'bg-warning/5 border-warning/40' : m.color === 'success' ? 'bg-success/5 border-success/40' : 'bg-error/5 border-error/40'
                    : 'bg-bg-base border-border-subtle',
                ]}>
                  <div class="flex items-center gap-space-12">
                    <span class:list={[
                      'w-10 h-10 rounded-full flex items-center justify-center font-mono-md text-[12px] font-bold',
                      m.color === 'error' ? 'bg-error/20 text-error' : m.color === 'warning' ? 'bg-warning/20 text-warning' : 'bg-success/20 text-success',
                    ]}>
                      {m.range}
                    </span>
                    <div class="flex flex-col">
                      <span class="font-h4 text-[14px] text-text-primary">{m.label}</span>
                      <span class="font-mono-md text-[11px] text-text-tertiary">Tạm ứng tối đa {m.advance}</span>
                    </div>
                  </div>
                  {m.current && (
                    <span class="px-space-12 py-space-4 rounded-full bg-warning text-[#0A1410] font-mono-md text-[11px] font-bold">Bạn đang ở đây</span>
                  )}
                </div>
              ))}
            </div>
          </div>

          <!-- Profile card -->
          <div class="bg-bg-elevated border border-border-subtle rounded-3xl p-space-32">
            <div class="flex items-center justify-between mb-space-16">
              <h3 class="font-h4 text-h4 text-text-primary">Thông tin cá nhân</h3>
              <span class="font-mono-md text-[11px] text-text-tertiary uppercase">Read-only · cập nhật ở Phase 2</span>
            </div>
            <div class="grid grid-cols-2 gap-y-space-16 gap-x-space-32">
              <div class="flex flex-col gap-space-4">
                <span class="font-mono-md text-[11px] text-text-tertiary uppercase">Họ tên</span>
                <span class="font-body-md text-[15px] text-text-primary">{USER.name}</span>
              </div>
              <div class="flex flex-col gap-space-4">
                <span class="font-mono-md text-[11px] text-text-tertiary uppercase">Số điện thoại</span>
                <span class="font-mono-md text-[15px] text-text-primary">{USER.phone}</span>
              </div>
              <div class="flex flex-col gap-space-4">
                <span class="font-mono-md text-[11px] text-text-tertiary uppercase">Email</span>
                <span class="font-body-md text-[15px] text-text-primary">{USER.email}</span>
              </div>
              <div class="flex flex-col gap-space-4">
                <span class="font-mono-md text-[11px] text-text-tertiary uppercase">Member từ</span>
                <span class="font-body-md text-[15px] text-text-primary">{formatDate(USER.memberSince)}</span>
              </div>
              <div class="col-span-2 flex flex-col gap-space-4">
                <span class="font-mono-md text-[11px] text-text-tertiary uppercase">Địa chỉ</span>
                <span class="font-body-md text-[15px] text-text-primary">{USER.address}, {USER.district}</span>
              </div>
            </div>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-4 gap-space-12">
            <div class="bg-bg-elevated border border-border-subtle rounded-2xl p-space-16 text-center">
              <span class="font-mono-md text-[10px] text-text-tertiary uppercase block">Đơn hoàn tất</span>
              <span class="font-mono-md text-[28px] text-text-primary font-bold">{STATS.totalOrders}</span>
            </div>
            <div class="bg-bg-elevated border border-border-subtle rounded-2xl p-space-16 text-center">
              <span class="font-mono-md text-[10px] text-tier-s uppercase block">Tier S</span>
              <span class="font-mono-md text-[28px] text-tier-s font-bold">{STATS.tierSCount}</span>
            </div>
            <div class="bg-bg-elevated border border-border-subtle rounded-2xl p-space-16 text-center">
              <span class="font-mono-md text-[10px] text-tier-c uppercase block">Tier C</span>
              <span class="font-mono-md text-[28px] text-tier-c font-bold">{STATS.tierCCount}</span>
            </div>
            <div class="bg-bg-elevated border border-border-subtle rounded-2xl p-space-16 text-center">
              <span class="font-mono-md text-[10px] text-success uppercase block">Mass balance TB</span>
              <span class="font-mono-md text-[28px] text-success font-bold">{(STATS.avgMassBalance * 100).toFixed(0)}%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
