---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNav from '../../components/nav/TopNav.astro';
import PersonaLinh from '../../components/illustrations/PersonaLinh.astro';
import { USER } from '../../lib/mock';

const addresses = [
  { id: 'home', label: 'Nhà', address: '123 Lê Văn Thiêm, P. Tân Phú', district: 'Q.7, TPHCM', primary: true },
  { id: 'office', label: 'Văn phòng', address: 'Tầng 12, Crescent Plaza', district: 'Q.7, TPHCM', primary: false },
];

const paymentMethods = [
  { id: 'zalopay', label: 'ZaloPay', detail: '0901-***-567', icon: 'payments', clay: 'bg-clay-sky', accent: 'text-info', primary: true },
  { id: 'cash', label: 'Tiền mặt', detail: 'Khi cần', icon: 'paid', clay: 'bg-clay-butter', accent: 'text-amber-deep', primary: false },
];

const notifPrefs = [
  { id: 'order_updates', label: 'Cập nhật đơn hàng', sub: 'ETA · trạng thái · BOM verified', push: true, sms: true, email: false },
  { id: 'payments', label: 'Giao dịch ví', sub: 'ZaloPay in/out · Hold release', push: true, sms: true, email: true },
  { id: 'promotions', label: 'Khuyến mãi & GP', sub: 'Voucher mới · Streak bonus · Referral', push: true, sms: false, email: true },
  { id: 'system', label: 'Hệ thống & bảo trì', sub: 'Outage · update · pháp lý', push: true, sms: false, email: false },
];
---

<BaseLayout title="Chỉnh sửa hồ sơ — RE-LOOP">
  <TopNav active="profile" />

  <main class="pt-[100px] pb-space-96 min-h-screen">
    <div class="max-w-[1280px] mx-auto px-[80px] flex flex-col gap-space-32">
      <a href="/profile.html" class="inline-flex items-center gap-space-8 font-mono-md text-[12px] text-text-secondary hover:text-tier-s font-semibold w-fit">
        <span class="material-symbols-rounded !text-[16px]">arrow_back</span>
        Hồ sơ
      </a>

      <!-- Hero -->
      <section class="grad-hero rounded-[40px] px-space-48 py-space-32 border border-border-subtle relative overflow-hidden">
        <div class="grid grid-cols-[1.4fr_1fr] gap-space-32 items-center">
          <div class="relative z-10">
            <span class="font-mono-md text-[11px] uppercase tracking-[0.2em] text-tier-s font-bold bg-clay-mint border-2 border-tier-s/30 rounded-full px-space-12 py-[4px] inline-flex items-center gap-space-8 shadow-clay-sm mb-space-12">
              <span class="material-symbols-rounded fill !text-[14px]">edit</span>
              CHỈNH SỬA HỒ SƠ
            </span>
            <h1 class="font-display-l text-[44px] font-extrabold leading-[1.05] tracking-tight text-text-primary mb-space-12">Cập nhật thông tin</h1>
            <p class="font-body-lg text-body-lg text-text-secondary">Tên · Địa chỉ · Phương thức thanh toán · Notif preferences · Privacy NĐ 13/2023</p>
          </div>
          <div class="relative h-[200px] flex items-center justify-center">
            <div class="w-[200px] h-[200px] rounded-full overflow-hidden shadow-clay-lg border-[6px] border-bg-elevated">
              <PersonaLinh class="w-full h-full" />
            </div>
            <button class="absolute bottom-space-8 right-space-32 w-12 h-12 rounded-2xl bg-text-primary text-white shadow-clay flex items-center justify-center hover:-translate-y-[2px] transition">
              <span class="material-symbols-rounded fill !text-[20px]">photo_camera</span>
            </button>
          </div>
        </div>
      </section>

      <div class="grid grid-cols-[2fr_1fr] gap-space-24">
        <div class="flex flex-col gap-space-24">
          <!-- Personal info -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-s font-semibold flex items-center gap-space-8">
              <span class="material-symbols-rounded fill !text-[16px]">person</span>
              THÔNG TIN CÁ NHÂN
            </span>
            <h2 class="font-h2 text-h2 text-text-primary mt-space-8 mb-space-24">Cơ bản</h2>
            <div class="grid grid-cols-2 gap-space-16">
              <div>
                <span class="font-mono-md text-[10px] uppercase tracking-wider text-text-tertiary font-semibold block mb-space-8">HỌ TÊN</span>
                <div class="bg-bg-surface rounded-2xl border-2 border-border-subtle shadow-inset-soft p-space-12 flex items-center gap-space-12">
                  <span class="material-symbols-rounded !text-[18px] text-text-tertiary">person</span>
                  <input type="text" value={USER.name} class="flex-1 bg-transparent border-0 focus:outline-none font-body-md text-[14px] text-text-primary" />
                </div>
              </div>
              <div>
                <span class="font-mono-md text-[10px] uppercase tracking-wider text-text-tertiary font-semibold block mb-space-8">SỐ ĐIỆN THOẠI</span>
                <div class="bg-bg-surface rounded-2xl border-2 border-tier-s/30 shadow-inset-soft p-space-12 flex items-center gap-space-12">
                  <span class="material-symbols-rounded !text-[18px] text-tier-s">verified</span>
                  <input type="tel" value={USER.phone} disabled class="flex-1 bg-transparent border-0 focus:outline-none font-mono-md text-[14px] text-text-primary tabular-nums" />
                  <span class="px-space-8 py-[2px] rounded-full bg-clay-mint border border-tier-s/30 font-mono-md text-[10px] text-tier-s font-bold">VERIFIED</span>
                </div>
              </div>
              <div>
                <span class="font-mono-md text-[10px] uppercase tracking-wider text-text-tertiary font-semibold block mb-space-8">EMAIL</span>
                <div class="bg-bg-surface rounded-2xl border-2 border-border-subtle shadow-inset-soft p-space-12 flex items-center gap-space-12">
                  <span class="material-symbols-rounded !text-[18px] text-text-tertiary">mail</span>
                  <input type="email" value={USER.email} class="flex-1 bg-transparent border-0 focus:outline-none font-body-md text-[14px] text-text-primary" />
                </div>
              </div>
              <div>
                <span class="font-mono-md text-[10px] uppercase tracking-wider text-text-tertiary font-semibold block mb-space-8">NGÀY SINH</span>
                <div class="bg-bg-surface rounded-2xl border-2 border-border-subtle shadow-inset-soft p-space-12 flex items-center gap-space-12">
                  <span class="material-symbols-rounded !text-[18px] text-text-tertiary">cake</span>
                  <input type="text" placeholder="dd/mm/yyyy" class="flex-1 bg-transparent border-0 focus:outline-none font-mono-md text-[14px] text-text-primary tabular-nums" />
                </div>
              </div>
            </div>
          </section>

          <!-- Addresses -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <div class="flex items-end justify-between mb-space-24">
              <div>
                <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-s font-semibold flex items-center gap-space-8">
                  <span class="material-symbols-rounded fill !text-[16px]">location_on</span>
                  ĐỊA CHỈ THU GOM
                </span>
                <h2 class="font-h2 text-h2 text-text-primary mt-space-8">Multi-address</h2>
              </div>
              <button class="bg-clay-mint text-tier-s border-2 border-tier-s/30 px-space-16 py-space-8 rounded-full font-mono-md text-[12px] font-bold shadow-clay-sm hover:shadow-clay flex items-center gap-space-8">
                <span class="material-symbols-rounded fill !text-[16px]">add</span>
                Thêm địa chỉ
              </button>
            </div>
            <div class="flex flex-col gap-space-12">
              {addresses.map((a) => (
                <div class:list={['flex items-start gap-space-16 p-space-16 rounded-2xl border-2 shadow-clay-sm', a.primary ? 'bg-clay-mint border-tier-s/30' : 'bg-bg-surface border-border-subtle']}>
                  <div class:list={['w-12 h-12 rounded-2xl flex items-center justify-center shadow-clay-sm', a.primary ? 'bg-bg-elevated' : 'bg-clay-mint']}>
                    <span class="material-symbols-rounded fill !text-[22px] text-tier-s">{a.label === 'Nhà' ? 'home' : 'apartment'}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-space-8 mb-space-4">
                      <span class="font-display font-bold text-[14px] text-text-primary">{a.label}</span>
                      {a.primary && <span class="px-space-8 py-[2px] rounded-full bg-tier-s text-white font-mono-md text-[10px] font-bold">MẶC ĐỊNH</span>}
                    </div>
                    <span class="font-body-md text-[13px] text-text-secondary block">{a.address}</span>
                    <span class="font-mono-md text-[11px] text-text-tertiary">{a.district}</span>
                  </div>
                  <button class="text-text-tertiary hover:text-tier-s">
                    <span class="material-symbols-rounded !text-[20px]">edit</span>
                  </button>
                  <button class="text-text-tertiary hover:text-tier-h">
                    <span class="material-symbols-rounded !text-[20px]">delete</span>
                  </button>
                </div>
              ))}
            </div>
          </section>

          <!-- Payment methods -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <div class="flex items-end justify-between mb-space-24">
              <div>
                <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-s font-semibold flex items-center gap-space-8">
                  <span class="material-symbols-rounded fill !text-[16px]">credit_card</span>
                  PHƯƠNG THỨC THANH TOÁN
                </span>
                <h2 class="font-h2 text-h2 text-text-primary mt-space-8">Nhận tiền</h2>
              </div>
              <button class="bg-clay-mint text-tier-s border-2 border-tier-s/30 px-space-16 py-space-8 rounded-full font-mono-md text-[12px] font-bold shadow-clay-sm hover:shadow-clay flex items-center gap-space-8">
                <span class="material-symbols-rounded fill !text-[16px]">add</span>
                Thêm
              </button>
            </div>
            <div class="grid grid-cols-2 gap-space-12">
              {paymentMethods.map((p) => (
                <div class:list={['flex items-center gap-space-12 p-space-16 rounded-2xl border-2 shadow-clay-sm', p.primary ? `${p.clay} border-${p.accent.replace('text-', '')}/40` : 'bg-bg-surface border-border-subtle']}>
                  <div class="w-12 h-12 rounded-2xl bg-bg-elevated flex items-center justify-center shadow-clay-sm">
                    <span class:list={['material-symbols-rounded fill !text-[22px]', p.accent]}>{p.icon}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-space-8">
                      <span class="font-display font-bold text-[14px] text-text-primary">{p.label}</span>
                      {p.primary && <span class="px-space-8 py-[2px] rounded-full bg-tier-s text-white font-mono-md text-[10px] font-bold">MẶC ĐỊNH</span>}
                    </div>
                    <span class="font-mono-md text-[11px] text-text-tertiary">{p.detail}</span>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Notification prefs -->
          <section class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-32">
            <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-s font-semibold flex items-center gap-space-8">
              <span class="material-symbols-rounded fill !text-[16px]">tune</span>
              NOTIFICATION PREFERENCES
            </span>
            <h2 class="font-h2 text-h2 text-text-primary mt-space-8 mb-space-24">Thông báo cho 4 nhóm</h2>
            <div class="overflow-hidden rounded-2xl border border-border-subtle">
              <table class="w-full">
                <thead class="bg-bg-surface">
                  <tr>
                    <th class="text-left px-space-16 py-space-12 font-mono-md text-[11px] uppercase tracking-wider text-text-tertiary font-bold">Nhóm</th>
                    <th class="text-center px-space-16 py-space-12 font-mono-md text-[11px] uppercase tracking-wider text-text-tertiary font-bold">Push</th>
                    <th class="text-center px-space-16 py-space-12 font-mono-md text-[11px] uppercase tracking-wider text-text-tertiary font-bold">SMS</th>
                    <th class="text-center px-space-16 py-space-12 font-mono-md text-[11px] uppercase tracking-wider text-text-tertiary font-bold">Email</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border-subtle">
                  {notifPrefs.map((n) => (
                    <tr class="bg-bg-elevated hover:bg-bg-surface/50">
                      <td class="px-space-16 py-space-12">
                        <span class="font-display font-bold text-[13px] text-text-primary block">{n.label}</span>
                        <span class="font-mono-md text-[11px] text-text-tertiary">{n.sub}</span>
                      </td>
                      <td class="text-center px-space-16 py-space-12">
                        <div class:list={['w-10 h-6 rounded-full mx-auto relative cursor-pointer transition', n.push ? 'bg-tier-s' : 'bg-bg-surface border border-border-default']}>
                          <div class:list={['w-5 h-5 rounded-full bg-white shadow-clay-sm absolute top-[2px] transition', n.push ? 'right-[2px]' : 'left-[2px]']}></div>
                        </div>
                      </td>
                      <td class="text-center px-space-16 py-space-12">
                        <div class:list={['w-10 h-6 rounded-full mx-auto relative cursor-pointer transition', n.sms ? 'bg-info' : 'bg-bg-surface border border-border-default']}>
                          <div class:list={['w-5 h-5 rounded-full bg-white shadow-clay-sm absolute top-[2px] transition', n.sms ? 'right-[2px]' : 'left-[2px]']}></div>
                        </div>
                      </td>
                      <td class="text-center px-space-16 py-space-12">
                        <div class:list={['w-10 h-6 rounded-full mx-auto relative cursor-pointer transition', n.email ? 'bg-amber-deep' : 'bg-bg-surface border border-border-default']}>
                          <div class:list={['w-5 h-5 rounded-full bg-white shadow-clay-sm absolute top-[2px] transition', n.email ? 'right-[2px]' : 'left-[2px]']}></div>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- Save -->
          <div class="flex gap-space-12">
            <button class="flex-1 bg-text-primary text-white py-space-16 rounded-2xl font-semibold shadow-clay text-[15px] inline-flex items-center justify-center gap-space-8 hover:-translate-y-[2px] transition">
              <span class="material-symbols-rounded fill !text-[20px]">save</span>
              Lưu thay đổi
            </button>
            <a href="/profile.html" class="bg-bg-elevated text-text-primary border border-border-subtle px-space-32 py-space-16 rounded-2xl font-semibold shadow-clay-sm text-[15px] inline-flex items-center gap-space-8 hover:shadow-clay">
              Huỷ
            </a>
          </div>
        </div>

        <!-- Right sidebar: privacy + danger zone -->
        <div class="flex flex-col gap-space-16">
          <div class="bg-clay-sky rounded-[24px] shadow-clay-sm border-2 border-info/30 p-space-24">
            <span class="material-symbols-rounded fill !text-[32px] text-info">policy</span>
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-info font-bold block mt-space-8">PRIVACY · NĐ 13/2023</span>
            <h4 class="font-h3 text-h3 text-text-primary mt-space-4 mb-space-12">Quyền riêng tư</h4>
            <p class="font-body-md text-[12px] text-text-secondary mb-space-16">RE-LOOP tuân thủ Nghị định 13/2023/NĐ-CP về bảo vệ dữ liệu cá nhân.</p>
            <ul class="flex flex-col gap-space-8">
              {[
                { icon: 'download', label: 'Export dữ liệu (JSON)' },
                { icon: 'history', label: 'Xem nhật ký truy cập' },
                { icon: 'block', label: 'Quản lý đối tác chia sẻ' },
              ].map((p) => (
                <li>
                  <button class="w-full flex items-center gap-space-8 p-space-8 bg-bg-elevated/60 rounded-xl border border-info/20 hover:bg-bg-elevated transition">
                    <span class="material-symbols-rounded !text-[16px] text-info">{p.icon}</span>
                    <span class="font-mono-md text-[12px] text-text-primary font-semibold flex-1 text-left">{p.label}</span>
                    <span class="material-symbols-rounded !text-[14px] text-text-tertiary">arrow_forward</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-clay-blush rounded-[24px] shadow-clay-sm border-2 border-tier-h/30 p-space-24">
            <span class="material-symbols-rounded fill !text-[32px] text-tier-h">dangerous</span>
            <span class="font-mono-md text-[11px] uppercase tracking-wider text-tier-h font-bold block mt-space-8">DANGER ZONE</span>
            <h4 class="font-h3 text-h3 text-text-primary mt-space-4 mb-space-12">Tài khoản</h4>
            <button class="w-full bg-bg-elevated text-tier-h border-2 border-tier-h/40 py-space-12 rounded-2xl font-semibold shadow-clay-sm text-[13px] inline-flex items-center justify-center gap-space-8 hover:shadow-clay mb-space-8">
              <span class="material-symbols-rounded fill !text-[16px]">logout</span>
              Đăng xuất
            </button>
            <button class="w-full bg-bg-elevated text-tier-h border-2 border-tier-h/40 py-space-12 rounded-2xl font-semibold shadow-clay-sm text-[13px] inline-flex items-center justify-center gap-space-8 hover:shadow-clay">
              <span class="material-symbols-rounded fill !text-[16px]">delete_forever</span>
              Xoá tài khoản
            </button>
            <p class="font-mono-md text-[10px] text-text-tertiary mt-space-8">Xoá vĩnh viễn theo NĐ 13/2023 trong 7 ngày · Số dư ZaloPay sẽ rút trước</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
