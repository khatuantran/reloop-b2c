---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthSidebar from '../components/auth/AuthSidebar.astro';

const steps = [
  { n: 1, label: 'Số điện thoại', icon: 'smartphone', href: '/login.html' },
  { n: 2, label: 'Nhập OTP', icon: 'sms', href: '/login/otp.html' },
];
---

<BaseLayout title="Đăng nhập · Bước 1 — RE-LOOP">
  <AuthShell flow="login" steps={steps} activeStep={1}>
    <div class="grid grid-cols-[1fr_400px] gap-space-32">
      <!-- Left: form card -->
      <div class="bg-bg-elevated rounded-[28px] shadow-clay border border-border-subtle p-space-48">
        <span class="font-mono-md text-[11px] uppercase tracking-[0.2em] text-tier-s font-bold mb-space-8 block">BƯỚC 1/2 · SỐ ĐIỆN THOẠI</span>
        <h1 class="font-display-l text-[40px] font-extrabold leading-tight tracking-tight text-text-primary mb-space-8">Chào mừng trở lại</h1>
        <p class="font-body-lg text-[15px] text-text-secondary mb-space-32 max-w-[480px]">
          Nhập số điện thoại đã đăng ký · OTP gửi qua SMS trong 10 giây
        </p>

        <!-- Phone input -->
        <span class="font-mono-md text-[11px] uppercase tracking-wider text-text-tertiary font-semibold block mb-space-8">SỐ ĐIỆN THOẠI</span>
        <div class="bg-bg-surface rounded-2xl border-2 border-tier-s shadow-inset-soft p-space-12 flex items-center gap-space-12 mb-space-12">
          <div class="bg-clay-mint border border-tier-s/30 rounded-xl px-space-12 py-space-8 flex items-center gap-space-8">
            <span class="text-[16px]">🇻🇳</span>
            <span class="font-mono-md text-[14px] text-text-primary font-bold">+84</span>
          </div>
          <input type="tel" value="901 234 567" autofocus class="flex-1 bg-transparent border-0 focus:outline-none font-mono-md text-[18px] text-text-primary tabular-nums" />
          <span class="material-symbols-rounded fill !text-[22px] text-tier-s">check_circle</span>
        </div>
        <p class="font-mono-md text-[11px] text-text-tertiary mb-space-24 inline-flex items-center gap-space-4">
          <span class="material-symbols-rounded !text-[14px]">info</span>
          Số phải khớp với tài khoản đã đăng ký
        </p>

        <a href="/login/otp.html" class="w-full bg-text-primary text-white py-space-16 rounded-2xl font-semibold shadow-clay text-[15px] inline-flex items-center justify-center gap-space-8 hover:-translate-y-[2px] transition mb-space-16">
          <span class="material-symbols-rounded fill !text-[20px]">sms</span>
          Gửi OTP qua SMS
        </a>

        <!-- Divider -->
        <div class="flex items-center gap-space-12 my-space-16">
          <div class="flex-1 h-px bg-border-subtle"></div>
          <span class="font-mono-md text-[10px] text-text-tertiary uppercase tracking-wider font-semibold">Hoặc</span>
          <div class="flex-1 h-px bg-border-subtle"></div>
        </div>

        <!-- Social auth -->
        <div class="grid grid-cols-2 gap-space-12 mb-space-24">
          <button class="bg-bg-surface text-text-primary border-2 border-border-subtle px-space-12 py-space-12 rounded-2xl font-semibold shadow-clay-sm text-[13px] inline-flex items-center justify-center gap-space-8 hover:shadow-clay hover:border-info transition">
            <div class="w-5 h-5 rounded-md bg-info flex items-center justify-center">
              <span class="font-display font-extrabold text-[10px] text-white">Z</span>
            </div>
            Đăng nhập Zalo
          </button>
          <button class="bg-bg-surface text-text-primary border-2 border-border-subtle px-space-12 py-space-12 rounded-2xl font-semibold shadow-clay-sm text-[13px] inline-flex items-center justify-center gap-space-8 hover:shadow-clay hover:border-tier-s transition">
            <span class="material-symbols-rounded fill !text-[16px] text-tier-s">fingerprint</span>
            Sinh trắc học
          </button>
        </div>

        <p class="font-body-md text-[12px] text-text-secondary text-center">
          Chưa có tài khoản? <a href="/signup.html" class="text-tier-s font-bold hover:underline">Đăng ký miễn phí</a>
        </p>
      </div>

      <!-- Right: sidebar -->
      <AuthSidebar flow="login" />
    </div>
  </AuthShell>
</BaseLayout>
