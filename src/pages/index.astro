---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/nav/TopNav.astro';
import HeroSection from '../components/home/HeroSection.astro';
import TierExplainerGrid from '../components/home/TierExplainerGrid.astro';
import TrustScoreSection from '../components/home/TrustScoreSection.astro';
import ImpactPreview from '../components/home/ImpactPreview.astro';
import OrderCard from '../components/order/OrderCard.astro';
import { ORDERS } from '../lib/mock';

const recentOrders = ORDERS.slice(0, 3);
---

<BaseLayout title="Trang chủ — RE-LOOP">
  <TopNav active="home" />

  <main class="pt-[100px] pb-space-96 min-h-screen">
    <div class="max-w-[1280px] mx-auto px-[80px]">
      <HeroSection />
      <TierExplainerGrid />
      <TrustScoreSection />
      <ImpactPreview />

      <!-- Recent orders -->
      <section>
        <div class="flex items-baseline justify-between mb-space-32">
          <div>
            <span class="font-mono-md text-[12px] uppercase tracking-wider text-tier-s">LỊCH SỬ</span>
            <h2 class="font-h1 text-h1 text-text-primary mt-space-8">Đơn gần nhất</h2>
          </div>
          <a href="/orders.html" class="font-body-md text-[14px] text-tier-s font-semibold hover:underline inline-flex items-center gap-space-8">
            Xem tất cả {ORDERS.length} đơn
            <span class="material-symbols-rounded !text-[16px]">arrow_forward</span>
          </a>
        </div>
        <div class="grid grid-cols-3 gap-space-24">
          {recentOrders.map((order) => <OrderCard order={order} />)}
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
